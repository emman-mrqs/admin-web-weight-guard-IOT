<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Recover Access</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/auth/adminForgetPassword.css">
</head>
<body class="h-screen w-full flex overflow-hidden">

    <div class="hidden lg:flex w-1/2 hero-pattern relative flex-col justify-between p-12 overflow-hidden border-r border-slate-800/60 shadow-[4px_0_24px_rgba(0,0,0,0.4)] z-10">
        <div class="absolute inset-0 ambient-dots z-0 opacity-50"></div>
        <div class="absolute inset-0 z-0 opacity-30 pointer-events-none flex items-center justify-center">
            <svg class="w-[120%] h-[120%] -ml-20" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
                <path class="connection-line text-emerald-400" stroke="currentColor" stroke-width="1.5" fill="none" d="M100,100 Q400,50 700,100 T400,400 T100,700" />
                <path class="connection-line text-blue-500" stroke="currentColor" stroke-width="1.5" fill="none" d="M50,400 Q200,300 400,400 T750,400" />
                <path class="connection-line text-teal-600" stroke="currentColor" stroke-width="1" fill="none" d="M100,700 Q300,600 750,400" />
                <circle cx="100" cy="100" r="4" fill="#34d399" class="animate-pulse" />
                <circle cx="700" cy="100" r="4" fill="#34d399" />
                <circle cx="400" cy="400" r="5" fill="#3b82f6" class="animate-pulse" />
                <circle cx="100" cy="700" r="4" fill="#34d399" />
                <circle cx="750" cy="400" r="4" fill="#0ea5e9" />
            </svg>
            <div class="absolute top-1/2 left-[45%] -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-emerald-500/10 rounded-full blur-3xl"></div>
        </div>

        <div class="relative z-10">
            <div class="flex items-center gap-3.5">
                <div class="w-12 h-12 bg-gradient-to-br from-emerald-400 to-teal-600 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-slate-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="14" height="10" rx="1"></rect>
                        <path d="M16 11h4a2 2 0 0 1 2 2v2h-6"></path>
                        <circle cx="6" cy="18" r="2"></circle>
                        <circle cx="18" cy="18" r="2"></circle>
                    </svg>
                </div>
                <span class="text-2xl font-extrabold tracking-tight text-white uppercase">WeighGuard</span>
            </div>
        </div>

        <div class="relative z-10 mb-20">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-800/50 border border-slate-700 backdrop-blur-md mb-6">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                <span class="text-[10px] font-bold text-slate-300 uppercase tracking-widest">Admin Portal v2.0</span>
            </div>
            <h1 class="text-5xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight">
                Command center for<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-400">fleet telemetry.</span>
            </h1>
            <p class="text-slate-400 text-lg max-w-md leading-relaxed font-medium">
                Monitor live cargo integrity, dispatch assignments globally, and intercept payload anomalies in real-time.
            </p>
        </div>

        <div class="relative z-10 flex gap-4">
            <div class="flex items-center gap-2 px-4 py-2 border border-slate-800 rounded-xl bg-slate-900/50 backdrop-blur-md shadow-inner text-xs font-bold text-slate-400">
                <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                End-to-End Encrypted
            </div>
        </div>
    </div>

    <div class="w-full lg:w-1/2 bg-slate-950 flex flex-col justify-center items-center p-8 sm:p-12 lg:p-24 relative z-20">
        
        <div class="lg:hidden absolute top-8 left-8 flex items-center gap-3.5">
            <div class="w-10 h-10 bg-gradient-to-br from-emerald-400 to-teal-600 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="14" height="10" rx="1"></rect>
                    <path d="M16 11h4a2 2 0 0 1 2 2v2h-6"></path>
                    <circle cx="6" cy="18" r="2"></circle>
                    <circle cx="18" cy="18" r="2"></circle>
                </svg>
            </div>
            <span class="text-xl font-extrabold tracking-tight text-white uppercase">WeighGuard</span>
        </div>

        <div class="w-full max-w-[400px]">
            
            <div id="step-1" class="block">
                <div class="mb-10 text-center lg:text-left">
                    <h2 class="text-3xl font-extrabold text-white tracking-tight mb-2">Recover Access</h2>
                    <p class="text-slate-400 text-sm font-medium">Enter your admin email to receive a secure 6-digit verification code.</p>
                </div>

                <form onsubmit="handleSendCode(event)" class="space-y-6">
                    <p id="forget-password-error-step-1" class="hidden text-xs text-rose-400 font-semibold"></p>
                    <div>
                        <label for="email" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Admin Email</label>
                        <div class="relative group">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                                <svg class="w-5 h-5 text-slate-500 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path></svg>
                            </span>
                            <input type="email" id="email" required 
                                class="w-full bg-slate-900 border border-slate-700 text-white text-sm font-medium rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all shadow-inner placeholder-slate-600" 
                                placeholder="admin@weighguard.io">
                        </div>
                    </div>

                    <button type="submit" id="send-code-btn" class="w-full bg-emerald-500 hover:bg-emerald-400 text-slate-950 text-sm font-extrabold py-4 rounded-xl transition-all shadow-[0_0_15px_rgba(52,211,153,0.3)] flex justify-center items-center gap-2 group mt-4 uppercase tracking-widest">
                        <span>Send Code</span>
                        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                    
                    <div class="mt-6 text-center">
                        <a href="/" class="text-xs font-bold text-slate-400 hover:text-white transition-colors uppercase tracking-widest">← Back to Login</a>
                    </div>
                </form>
            </div>

            <div id="step-2" class="hidden">
                <div class="mb-10 text-center lg:text-left">
                    <h2 class="text-3xl font-extrabold text-white tracking-tight mb-2">Verify Identity</h2>
                    <p class="text-slate-400 text-sm font-medium">A transmission has been sent to <span id="display-email" class="text-emerald-400">your email</span>. Enter the 6-digit sequence below.</p>
                </div>

                <form onsubmit="handleVerifyCode(event)" class="space-y-6">
                    <p id="forget-password-error-step-2" class="hidden text-xs text-rose-400 font-semibold"></p>
                    <div>
                        <label for="verification-code" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Verification Code</label>
                        <div class="relative group">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                                <svg class="w-5 h-5 text-slate-500 group-focus-within:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </span>
                            <input type="text" id="verification-code" required maxlength="6" pattern="\d{6}"
                                class="w-full bg-slate-900 border border-slate-700 text-white text-xl font-bold rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all shadow-inner placeholder-slate-600 tracking-ultra text-center" 
                                placeholder="••••••">
                        </div>
                    </div>

                    <button type="submit" id="verify-btn" class="w-full bg-blue-500 hover:bg-blue-400 text-slate-950 text-sm font-extrabold py-4 rounded-xl transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] flex justify-center items-center gap-2 group mt-4 uppercase tracking-widest">
                        <span>Authenticate Code</span>
                        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>

                    <div class="mt-6 text-center">
                        <button type="button" onclick="resetToStep1()" class="text-xs font-bold text-slate-400 hover:text-white transition-colors uppercase tracking-widest">Wrong Email?</button>
                    </div>
                </form>
            </div>

            <div id="step-3" class="hidden">
                <div class="mb-10 text-center lg:text-left">
                    <h2 class="text-3xl font-extrabold text-white tracking-tight mb-2">Set New Password</h2>
                    <p class="text-slate-400 text-sm font-medium">Choose a new secure password for your administrator account.</p>
                </div>

                <form onsubmit="handleResetPassword(event)" class="space-y-6">
                    <p id="forget-password-error-step-3" class="hidden text-xs text-rose-400 font-semibold"></p>
                    <div>
                        <label for="new-password" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">New Password</label>
                        <div class="relative group">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                                <svg class="w-5 h-5 text-slate-500 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8"></path></svg>
                            </span>
                            <input type="password" id="new-password" minlength="8" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm font-medium rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all shadow-inner placeholder-slate-600" placeholder="At least 8 characters">
                        </div>
                    </div>

                    <div>
                        <label for="confirm-password" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Confirm Password</label>
                        <div class="relative group">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                                <svg class="w-5 h-5 text-slate-500 group-focus-within:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016"></path></svg>
                            </span>
                            <input type="password" id="confirm-password" minlength="8" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm font-medium rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all shadow-inner placeholder-slate-600" placeholder="Retype your password">
                        </div>
                    </div>

                    <button type="submit" id="reset-password-btn" class="w-full bg-emerald-500 hover:bg-emerald-400 text-slate-950 text-sm font-extrabold py-4 rounded-xl transition-all shadow-[0_0_15px_rgba(52,211,153,0.3)] flex justify-center items-center gap-2 group mt-4 uppercase tracking-widest">
                        <span>Update Password</span>
                        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </form>
            </div>

            <div id="step-4" class="hidden text-center lg:text-left">
                <div class="w-16 h-16 bg-emerald-500/20 text-emerald-400 rounded-full flex items-center justify-center mb-6 mx-auto lg:mx-0 border border-emerald-500/30">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                </div>

                <h2 class="text-3xl font-extrabold text-white tracking-tight mb-4">Credentials Reset</h2>
                <p class="text-slate-400 text-sm font-medium mb-8 leading-relaxed">Your administrator password has been updated successfully. You can now log in with your new credentials.</p>

                <a href="/" class="w-full bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 text-sm font-extrabold py-4 rounded-xl transition-all flex justify-center items-center gap-2 uppercase tracking-widest">
                    <span>Back to Login</span>
                </a>
            </div>

            <div class="mt-12 text-center lg:text-left">
                <p class="text-[10px] text-slate-600 font-bold uppercase tracking-widest leading-relaxed">
                    Access restricted to authorized personnel only.<br>
                    Protected by WeighGuard Security Protocols.
                </p>
            </div>
        </div>
    </div>

    <script src="/js/auth/adminForgetPassword.js"></script>
</body>
</html>