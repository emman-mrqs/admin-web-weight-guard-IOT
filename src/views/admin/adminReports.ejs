<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Reports & Analytics</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2310b981' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3E%3Crect x='2' y='7' width='14' height='10' rx='1'/%3E%3Cpath d='M16 11h4a2 2 0 0 1 2 2v2h-6'/%3E%3Ccircle cx='6' cy='18' r='2'/%3E%3Ccircle cx='18' cy='18' r='2'/%3E%3C/svg%3E">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <link rel="stylesheet" href="/css/admin/adminReports.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden relative bg-slate-950">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 shrink-0 z-10 sticky top-0">
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">Reports & Analytics</h1>
                <p class="text-xs text-slate-400 font-medium mt-0.5">Deep dive into fleet performance and cargo safety</p>
            </div>
            <div class="flex items-center gap-5">
                <div class="flex bg-slate-950 rounded-xl p-1.5 border border-slate-800 shadow-inner">
                    <button id="btnReportsWeekly" data-range="weekly" class="px-5 py-2 text-xs font-bold uppercase tracking-widest bg-slate-800 text-white rounded-lg shadow-sm transition">WEEKLY</button>
                    <button id="btnReportsMonthly" data-range="monthly" class="px-5 py-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-slate-300 hover:bg-slate-800/50 rounded-lg transition">MONTHLY</button>
                </div>
                <button id="btnExportPdf" class="bg-emerald-500 text-slate-900 px-5 py-2.5 rounded-xl text-xs font-extrabold flex items-center gap-2 hover:bg-emerald-400 transition shadow-[0_0_15px_rgba(52,211,153,0.4)] tracking-wide uppercase">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    EXPORT PDF
                </button>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
            <div id="reportsErrorBanner" class="hidden rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-xs text-rose-300"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 shrink-0">
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4">
                    <div class="p-3 bg-blue-500/10 border border-blue-500/20 rounded-xl text-blue-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Total Cargo Moved</p>
                        <p class="text-2xl font-extrabold text-white leading-none"><span id="statTotalCargo">14.2</span> <span class="text-sm font-semibold text-slate-500">tons</span></p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
                    <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Avg Efficiency</p>
                        <p class="text-2xl font-extrabold text-white leading-none"><span id="statAvgEfficiency">94</span><span class="text-sm font-semibold text-slate-500">%</span></p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4">
                    <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-amber-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Avg Transit Time</p>
                        <p class="text-2xl font-extrabold text-white leading-none"><span id="statAvgTransitTime">42</span> <span class="text-sm font-semibold text-slate-500">mins</span></p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]"></div>
                    <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl text-rose-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Active Alerts</p>
                        <p id="statActiveAlerts" class="text-2xl font-extrabold text-rose-400 leading-none">3</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <div class="lg:col-span-2 bg-slate-900 rounded-2xl border border-slate-800 shadow-lg p-6 flex flex-col">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <h3 class="text-lg font-extrabold text-white tracking-tight">Cargo Weight Trends</h3>
                            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-1">Total weight transported vs efficiency target</p>
                        </div>
                        <div class="flex items-center gap-4 bg-slate-950 border border-slate-800 px-4 py-2 rounded-xl shadow-inner">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_5px_rgba(52,211,153,0.8)]"></span>
                                <span class="text-xs font-bold text-slate-300">Actual Weight</span>
                            </div>
                            <div class="w-px h-4 bg-slate-700"></div>
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-slate-500"></span>
                                <span class="text-xs font-bold text-slate-300">Target</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex-1 min-h-[300px] relative w-full">
                        <canvas id="weightTrendChart"></canvas>
                    </div>
                </div>

                <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg p-6 flex flex-col">
                    <h3 class="text-lg font-extrabold text-white tracking-tight mb-2">Incident Distribution</h3>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-6">Breakdown of recorded events</p>
                    
                    <div class="h-56 relative w-full flex items-center justify-center">
                        <canvas id="incidentDistributionChart"></canvas>
                    </div>
                    
                    <div class="mt-8 space-y-4">
                        <div>
                            <div class="flex justify-between items-center text-xs font-bold mb-1.5">
                                <span class="text-slate-400 uppercase tracking-wide">Cargo Loss</span>
                                <span id="incidentLossPct" class="text-rose-400">12%</span>
                            </div>
                            <div class="w-full bg-slate-950 h-1.5 rounded-full overflow-hidden shadow-inner border border-slate-800">
                                <div id="incidentLossBar" class="bg-rose-500 h-full w-[12%] rounded-full shadow-[0_0_10px_rgba(244,63,94,0.8)]"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between items-center text-xs font-bold mb-1.5">
                                <span class="text-slate-400 uppercase tracking-wide">Overload Warning</span>
                                <span id="incidentOverloadPct" class="text-amber-400">34%</span>
                            </div>
                            <div class="w-full bg-slate-950 h-1.5 rounded-full overflow-hidden shadow-inner border border-slate-800">
                                <div id="incidentOverloadBar" class="bg-amber-400 h-full w-[34%] rounded-full shadow-[0_0_10px_rgba(251,191,36,0.8)]"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between items-center text-xs font-bold mb-1.5">
                                <span class="text-slate-400 uppercase tracking-wide">Normal Operation</span>
                                <span id="incidentNormalPct" class="text-emerald-400">54%</span>
                            </div>
                            <div class="w-full bg-slate-950 h-1.5 rounded-full overflow-hidden shadow-inner border border-slate-800">
                                <div id="incidentNormalBar" class="bg-emerald-400 h-full w-[54%] rounded-full shadow-[0_0_10px_rgba(52,211,153,0.8)]"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                
                <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg p-6 flex flex-col">
                    <h3 class="text-lg font-extrabold text-white tracking-tight mb-2">Fleet Efficiency by Dispatch Location</h3>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-6">Performance score across completed dispatch coordinates</p>
                    <div class="flex-1 min-h-[250px] relative w-full">
                        <canvas id="zoneEfficiencyChart"></canvas>
                    </div>
                </div>

                <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg p-6 flex flex-col justify-between">
                    <div>
                        <h3 class="text-lg font-extrabold text-white tracking-tight mb-2">Monthly Performance Summary</h3>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Overall performance score based on safety and load targets.</p>
                    </div>
                    
                    <div class="flex items-center gap-8 py-8 px-4">
                        <div class="text-center shrink-0">
                            <div class="relative inline-flex items-center justify-center">
                                <svg class="w-28 h-28 transform -rotate-90">
                                    <circle cx="56" cy="56" r="50" stroke="currentColor" stroke-width="8" fill="transparent" class="text-slate-950" />
                                    <circle id="safetyScoreCircle" cx="56" cy="56" r="50" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="314" stroke-dashoffset="18" class="text-emerald-400 drop-shadow-[0_0_10px_rgba(52,211,153,0.6)]" stroke-linecap="round" />
                                </svg>
                                <div class="absolute flex flex-col items-center">
                                    <p class="text-4xl font-extrabold text-white"><span id="safetyScoreValue">94</span><span class="text-xl text-emerald-400">%</span></p>
                                </div>
                            </div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-4">Safety Score</p>
                        </div>

                        <div class="flex-1 space-y-6">
                            <div>
                                <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest mb-2">
                                    <span class="text-slate-400">Delivery Speed</span>
                                    <span id="deliverySpeedPct" class="text-emerald-400 font-extrabold">88%</span>
                                </div>
                                <div class="w-full bg-slate-950 h-2.5 rounded-full overflow-hidden shadow-inner border border-slate-800">
                                    <div id="deliverySpeedBar" class="bg-emerald-400 h-full w-[88%] rounded-full shadow-[0_0_10px_rgba(52,211,153,0.8)]"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest mb-2">
                                    <span class="text-slate-400">Fuel Efficiency</span>
                                    <span id="fuelEfficiencyPct" class="text-blue-400 font-extrabold">76%</span>
                                </div>
                                <div class="w-full bg-slate-950 h-2.5 rounded-full overflow-hidden shadow-inner border border-slate-800">
                                    <div id="fuelEfficiencyBar" class="bg-blue-500 h-full w-[76%] rounded-full shadow-[0_0_10px_rgba(59,130,246,0.8)]"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button id="btnExportCsv" class="w-full py-4 bg-slate-800 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl hover:bg-slate-700 hover:text-white transition uppercase tracking-widest flex items-center justify-center gap-2 shadow-md">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Download Full Dataset (CSV)
                    </button>
                </div>
            </div>
        </div>
    </main>

    <script src="/js/admin/adminReports.js"></script>
</body>
</html>