<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Live Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/admin/adminFleet.css">
    <style>
        /* Ensure map fills the entire container */
        #live-fleet-map { height: 100%; width: 100%; z-index: 0; }
        .glass-panel { background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(51, 65, 85, 0.5); }
    </style>
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar', { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col relative overflow-hidden">
        
        <div id="live-fleet-map"></div>

        <div class="absolute top-6 left-8 right-8 z-[1000] flex justify-between items-center pointer-events-none">
            <div class="flex items-center gap-4 pointer-events-auto">
                <div class="glass-panel px-5 py-3 rounded-2xl shadow-2xl flex items-center gap-4">
                    <div class="flex items-center gap-2">
                        <span class="relative flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                        </span>
                        <h1 class="text-white font-extrabold tracking-tight uppercase text-sm">Live System</h1>
                    </div>
                    <div class="h-4 w-px bg-slate-700"></div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">114 Active Units</p>
                </div>
            </div>

            <div class="flex items-center gap-3 pointer-events-auto">
                <div class="relative group">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4">
                        <svg class="w-4 h-4 text-slate-500 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </span>
                    <input type="text" placeholder="Track vehicle ID..." class="glass-panel rounded-xl pl-11 pr-4 py-3 w-64 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 text-sm text-white placeholder-slate-500 transition-all">
                </div>
            </div>
        </div>

        <div class="absolute bottom-10 right-8 z-[1000] w-80 pointer-events-auto">
            <div class="glass-panel rounded-2xl shadow-2xl overflow-hidden border border-rose-500/20">
                <div class="p-4 bg-rose-500/10 border-b border-slate-800 flex justify-between items-center">
                    <h3 class="text-[10px] font-bold text-rose-400 uppercase tracking-widest">Priority Incidents</h3>
                    <span class="text-[10px] font-mono text-rose-500/80">LIVE</span>
                </div>
                <div class="max-h-60 overflow-y-auto custom-scrollbar p-4 space-y-4">
                    <div class="flex gap-3 border-l-2 border-rose-500 pl-3 py-1 cursor-pointer hover:bg-white/5 transition rounded-r-lg">
                        <div>
                            <p class="text-xs font-bold text-white">#RC-0034 <span class="text-rose-400">Cargo Loss</span></p>
                            <p class="text-[10px] text-slate-500 mt-0.5">Rodriguez, Rizal &bull; 2 mins ago</p>
                        </div>
                    </div>
                    <div class="flex gap-3 border-l-2 border-amber-500 pl-3 py-1 cursor-pointer hover:bg-white/5 transition rounded-r-lg">
                        <div>
                            <p class="text-xs font-bold text-white">#RC-7721 <span class="text-amber-400">Overload</span></p>
                            <p class="text-[10px] text-slate-500 mt-0.5">Payatas Rd &bull; 14 mins ago</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="absolute bottom-10 left-8 z-[1000] flex flex-col gap-2 pointer-events-auto">
            <button class="glass-panel p-3 rounded-xl text-slate-400 hover:text-white transition" title="Recenter Map">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
            </button>
            <button class="glass-panel p-3 rounded-xl text-slate-400 hover:text-white transition" title="Toggle Traffic">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1"></path></svg>
            </button>
        </div>

    </main>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/js/admin/adminFleetMaps.js"></script>
</body>
</html>