<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - User Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/admin/adminUsers.css">

</head>
<body class="flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>


    <!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col overflow-hidden relative">
        <!-- HEADER -->
        <header class="h-20 bg-[#0B0E14] border-b border-gray-800 flex items-center justify-between px-8 shrink-0">
            <div>
                <h1 class="text-2xl font-bold text-white">User Management</h1>
                <p class="text-xs text-gray-500 font-medium">Control permissions and platform access</p>
            </div>
            <div class="flex items-center gap-4">
                <!-- Assign Task Button -->
                <button onclick="openAssignTaskModal()" class="bg-gray-800 border border-gray-600 text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 hover:bg-gray-700 transition shadow-sm">
                    <svg class="w-4 h-4 text-[#2DD4BF]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    ASSIGN TASK
                </button>
                <!-- Add User Button -->
                <button onclick="openModal('addUserModal')" class="bg-[#2DD4BF] text-black px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 hover:bg-teal-300 transition shadow-lg shadow-teal-900/20">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M12 4v16m8-8H4"></path></svg>
                    ADD NEW USER
                </button>
                <button class="relative p-2 text-gray-400 hover:text-white transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    <span class="absolute top-2 right-2.5 w-2 h-2 bg-red-500 rounded-full border border-[#0B0E14]"></span>
                </button>
            </div>
        </header>

        <!-- DASHBOARD BODY -->
        <div class="flex-1 overflow-hidden p-8 flex flex-col">
            
            <!-- SUMMARY STATS -->
            <div id="summaryStats" class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6 shrink-0">
                

            </div>

            <!-- TAB NAVIGATION -->
            <div class="flex gap-6 border-b border-gray-800 mb-6 shrink-0">
                <button id="tab-list" onclick="switchView('list')" class="px-4 py-2 text-sm font-bold tab-active transition-all">User List</button>
                <button id="tab-map" onclick="switchView('map')" class="px-4 py-2 text-sm font-bold tab-inactive transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    Live Map View
                </button>
            </div>

            <!-- VIEW CONTAINER -->
            <div class="flex-1 overflow-hidden relative">
                
                <!-- LIST VIEW (Default) -->
                <div id="listView" class="flex flex-col h-full absolute inset-0 transition-opacity duration-300">
                    <!-- Filters -->
                    <div class="flex flex-col md:flex-row gap-4 justify-between items-center mb-6 shrink-0">
                        <div class="relative w-full md:w-96">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </span>
                            <input type="text" placeholder="Search by name or email..." class="w-full bg-[#111827] border border-gray-700 text-sm rounded-lg pl-10 pr-4 py-2.5 focus:outline-none focus:border-[#2DD4BF] text-gray-300 transition">
                        </div>
                        <div class="flex gap-2 w-full md:w-auto">
                            <select class="bg-[#111827] border border-gray-700 text-xs font-bold text-gray-400 rounded-lg px-4 py-2.5 focus:outline-none focus:border-[#2DD4BF] flex-1">
                                <option>All Assignments</option>
                                <option>In Transit</option>
                                <option>Idle</option>
                                <option>Unassigned</option>
                            </select>
                            <select class="bg-[#111827] border border-gray-700 text-xs font-bold text-gray-400 rounded-lg px-4 py-2.5 focus:outline-none focus:border-[#2DD4BF] flex-1">
                                <option>All Status</option>
                                <option>Active</option>
                                <option>Inactive</option>
                                <option>Pending</option>
                            </select>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="card-bg rounded-xl overflow-hidden flex-1">
                        <div class="overflow-y-auto custom-scrollbar h-full">
                            <table class="w-full text-left">
                                <thead class="sticky top-0 bg-[#111827] z-10">
                                    <tr class="text-gray-500 text-[10px] uppercase font-bold border-b border-gray-800">
                                        <th class="px-6 py-4">User</th>
                                        <th class="px-6 py-4">Assignment</th>
                                        <th class="px-6 py-4">Status</th>
                                        <th class="px-6 py-4">Created At</th>
                                        <th class="px-6 py-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody" class="divide-y divide-gray-800">
                                    <!-- User rows will be populated here dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- MAP VIEW (Hidden by Default) -->
                <div id="mapView" class="hidden absolute inset-0 flex gap-6 h-full transition-opacity duration-300">
                    <!-- Left: Active Assignments List -->
                    <div class="w-1/4 card-bg rounded-xl overflow-hidden flex flex-col border border-gray-800">
                        <div class="p-4 border-b border-gray-700 bg-[#111827]">
                            <h3 class="text-white font-bold text-sm">Active Assignments</h3>
                            <p class="text-xs text-gray-500">Select to view route</p>
                        </div>
                        <div id="assignmentsList" class="flex-1 overflow-y-auto custom-scrollbar p-2 space-y-2">
                            <!-- Driver assignments will be populated dynamically -->
                            <div class="p-4 text-center text-gray-500 text-xs">
                                <svg class="w-8 h-8 mx-auto mb-2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                Loading assignments...
                            </div>
                        </div>
                    </div>

                    <!-- Right: Map and Task Details -->
                    <div class="flex-1 flex flex-col gap-4">
                        <!-- Map Container -->
                        <div class="flex-1 card-bg rounded-xl overflow-hidden relative border border-gray-800">
                            <div id="users-map" class="w-full h-full"></div>
                            
                            <!-- Map Legend -->
                            <div class="absolute top-4 left-4 z-[40] bg-[#0B0E14]/90 backdrop-blur-md p-3 rounded-lg border border-gray-700 text-xs shadow-xl pointer-events-none">
                                <p class="font-bold text-white mb-2">Route Legend</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded-full bg-[#2DD4BF]"></span>
                                        <span class="text-gray-400">Pickup Point</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded-full bg-red-500"></span>
                                        <span class="text-gray-400">Destination</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="w-6 h-0.5 bg-blue-500 rounded"></span>
                                        <span class="text-gray-400">Route Path</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Refresh Button -->
                            <button onclick="loadMapAssignments()" class="absolute top-4 right-4 z-[40] bg-[#0B0E14]/90 hover:bg-[#1F2937] backdrop-blur-md p-2.5 rounded-lg border border-gray-700 text-gray-400 hover:text-white transition shadow-xl" title="Refresh Assignments">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            </button>
                        </div>

                        <!-- Selected Task Route Details Panel -->
                        <div id="selectedTaskDetails" class="hidden card-bg rounded-xl border border-gray-800 p-4">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <div class="p-2 bg-[#2DD4BF]/10 rounded-lg">
                                        <svg class="w-5 h-5 text-[#2DD4BF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                    </div>
                                    <div>
                                        <p id="selectedDriverName" class="text-sm font-bold text-white">Driver Name</p>
                                        <p id="selectedVehicle" class="text-[10px] text-gray-500">#RC-0000</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <!-- Edit Assignment Button -->
                                    <button onclick="openEditAssignmentModal()" class="p-2 text-blue-400 hover:text-blue-300 transition bg-blue-900/20 rounded-lg border border-blue-500/30 hover:border-blue-500/50" title="Edit Assignment">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </button>
                                    <!-- Delete Assignment Button -->
                                    <button onclick="openDeleteAssignmentModal()" class="p-2 text-red-500 hover:text-red-400 transition bg-red-900/20 rounded-lg border border-red-500/30 hover:border-red-500/50" title="Delete Assignment">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                    <!-- Close Button -->
                                    <button onclick="hideTaskDetails()" class="text-gray-400 hover:text-white transition p-1.5 hover:bg-gray-700/50 rounded-lg" title="Close">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Trip Stats -->
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
                                <div class="bg-gray-800/50 rounded-lg p-3">
                                    <p class="text-[10px] text-gray-500 uppercase font-bold">Distance</p>
                                    <p id="selectedDistance" class="text-sm font-bold text-white font-mono">-- km</p>
                                </div>
                                <div class="bg-gray-800/50 rounded-lg p-3">
                                    <p class="text-[10px] text-gray-500 uppercase font-bold">Duration</p>
                                    <p id="selectedDuration" class="text-sm font-bold text-white font-mono">-- min</p>
                                </div>
                                <div class="bg-gray-800/50 rounded-lg p-3">
                                    <p class="text-[10px] text-gray-500 uppercase font-bold">Status</p>
                                    <p id="selectedStatus" class="text-sm font-bold text-[#2DD4BF]">Active</p>
                                </div>
                                <div class="bg-gray-800/50 rounded-lg p-3">
                                    <p class="text-[10px] text-gray-500 uppercase font-bold">Started</p>
                                    <p id="selectedStartTime" class="text-sm font-bold text-white">--</p>
                                </div>
                            </div>

                            <!-- Route Directions Toggle -->
                            <div id="mapRouteDirections" class="hidden">
                                <button type="button" onclick="toggleMapDirections()" class="w-full flex items-center justify-between bg-gray-800/50 hover:bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 transition group">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                        <span class="text-sm font-bold text-white">Route Directions</span>
                                        <span id="mapRouteSummary" class="text-[10px] text-gray-400"></span>
                                    </div>
                                    <svg id="mapDirectionsChevron" class="w-4 h-4 text-gray-400 transition transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div id="mapDirectionsContent" class="hidden mt-2 bg-gray-800/30 border border-gray-700 rounded-lg overflow-hidden">
                                    <div class="max-h-32 overflow-y-auto custom-scrollbar">
                                        <ul id="mapDirectionsList" class="divide-y divide-gray-700/50 text-sm"></ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- ASSIGN TASK MODAL -->
<div id="assignTaskModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeAssignTaskModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-[#111827] border border-gray-700 w-full max-w-2xl rounded-xl shadow-2xl p-0 transform transition-all duration-300 modal-content-enter modal-content flex flex-col max-h-[90vh]">
            
            <!-- Header -->
            <div class="flex justify-between items-center p-6 border-b border-gray-800">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <div class="p-2 bg-[#2DD4BF]/10 rounded-lg">
                        <svg class="w-5 h-5 text-[#2DD4BF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    </div>
                    Assign New Task
                </h2>
                <button onclick="closeAssignTaskModal()" class="text-gray-400 hover:text-white transition p-2 hover:bg-gray-800 rounded-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Scrollable Content Area -->
            <div class="overflow-y-auto flex-1 p-6 custom-scrollbar">
                <form id="assignTaskForm" class="space-y-5" onsubmit="event.preventDefault();">
                    
                    <!-- Error/Success Messages -->
                    <p id="taskFormError" class="text-red-500 text-sm"></p>
                    <p id="taskFormSuccess" class="text-green-500 text-sm"></p>
                    
                    <!-- Driver & Vehicle Section -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1.5 ml-1">Select Driver</label>
                            <div class="relative">
                                <select id="taskDriverSelect" class="w-full bg-[#1F2937] border border-gray-700 text-white text-sm rounded-lg pl-3 pr-8 py-3 focus:outline-none focus:border-[#2DD4BF] focus:ring-1 focus:ring-[#2DD4BF] appearance-none transition-colors">
                                    <option value="">Loading drivers...</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-400">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1.5 ml-1">Vehicle Number</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm font-mono">#RC-</span>
                                <input type="text" id="taskVehicleSelect" placeholder="0000" maxlength="4" class="w-full bg-[#1F2937] border border-gray-700 text-white text-sm rounded-lg pl-12 pr-3 py-3 focus:outline-none focus:border-[#2DD4BF] focus:ring-1 focus:ring-[#2DD4BF] font-mono transition-colors">
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-gray-800 my-2"></div>

                    <!-- Map Interaction Header -->
                    <div class="flex justify-between items-end">
                        <label class="block text-xs font-bold text-gray-400 uppercase">Route Details</label>
                        <span class="text-[10px] text-gray-500 bg-gray-800 px-2 py-1 rounded">Click inputs to set mode</span>
                    </div>

                    <!-- Location Inputs Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Pickup Input -->
                        <div class="relative group">
                            <label class="block text-[10px] font-bold text-[#2DD4BF] uppercase mb-1 ml-1 flex items-center gap-1">
                                <span class="w-2 h-2 rounded-full bg-[#2DD4BF]"></span> Pickup Location (A)
                            </label>
                            <input type="text" id="pickupInput" onclick="setTaskMode('pickup')" readonly
                                class="w-full bg-[#1F2937] border border-[#2DD4BF] text-white text-sm rounded-lg pl-9 pr-3 py-3 focus:outline-none cursor-pointer transition-all shadow-[0_0_10px_rgba(45,212,191,0.1)] hover:bg-gray-800" 
                                placeholder="Click on map to set...">
                            <!-- Icon inside input -->
                            <div class="absolute left-3 top-[34px] text-[#2DD4BF]">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </div>
                        </div>

                        <!-- Destination Input -->
                        <div class="relative group">
                            <label class="block text-[10px] font-bold text-red-400 uppercase mb-1 ml-1 flex items-center gap-1">
                                <span class="w-2 h-2 rounded-full bg-red-400"></span> Destination (B)
                            </label>
                            <input type="text" id="destInput" onclick="setTaskMode('dest')" readonly
                                class="w-full bg-[#1F2937] border border-gray-700 text-white text-sm rounded-lg pl-9 pr-3 py-3 focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 cursor-pointer transition-all hover:bg-gray-800" 
                                placeholder="Click on map to set...">
                            <!-- Icon inside input -->
                            <div class="absolute left-3 top-[34px] text-red-400">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </div>
                        </div>
                    </div>

                    <!-- TRIP STATS DISPLAY (Hidden by default) -->
                    <div id="tripStats" class="hidden relative overflow-hidden bg-gray-800/50 border border-gray-700 rounded-xl p-4 flex flex-col sm:flex-row justify-around items-center gap-4 animate-fadeIn">
                         <!-- Glow Effect -->
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#2DD4BF] to-transparent opacity-50"></div>
                        
                        <!-- Time -->
                        <div class="flex items-center gap-3 w-full sm:w-auto justify-center sm:justify-start">
                            <div class="p-2.5 rounded-lg bg-blue-500/10 text-blue-400">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Est. Duration</p>
                                <p id="timeVal" class="text-lg font-bold text-white font-mono">-- min</p>
                            </div>
                        </div>
                        
                        <!-- Divider (Desktop) -->
                        <div class="hidden sm:block h-8 w-px bg-gray-700"></div>
                        
                        <!-- Distance -->
                        <div class="flex items-center gap-3 w-full sm:w-auto justify-center sm:justify-start">
                            <div class="p-2.5 rounded-lg bg-emerald-500/10 text-emerald-400">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Total Distance</p>
                                <p id="distVal" class="text-lg font-bold text-white font-mono">-- km</p>
                            </div>
                        </div>
                    </div>

                    <!-- MAP CONTAINER -->
