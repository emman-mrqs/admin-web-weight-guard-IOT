                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold tracking-wide">ACTIVE</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="deleteUserModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-sm bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300">
        <div class="p-6 text-center space-y-4">
            <div class="w-16 h-16 bg-rose-500/10 border border-rose-500/30 rounded-full flex items-center justify-center mx-auto text-rose-500 mb-2 shadow-[0_0_15px_rgba(244,63,94,0.2)]">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-white tracking-tight">Delete User Account?</h2>
            
            <input type="hidden" id="deleteUserId">

            <div class="bg-rose-950/20 border border-rose-500/20 rounded-xl p-4 mb-2 text-left">
                <p class="text-xs text-slate-400 uppercase tracking-widest font-bold mb-1">Target User</p>
                <p class="text-sm font-bold text-white mb-2" id="deleteUserName">User Name Here</p>
                <p class="text-[10px] text-slate-500 leading-relaxed">This action cannot be undone. All user data, assignment history, and login access will be permanently wiped.</p>
            </div>

            <p id="deleteFormError" class="text-rose-500 text-xs hidden"></p>
            <p id="deleteFormSuccess" class="text-emerald-500 text-xs hidden"></p>

            <div class="pt-4 flex gap-3">
                <button type="button" onclick="closeModal('deleteUserModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="confirmDeleteUser()" class="flex-1 px-4 py-3 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-bold transition shadow-[0_0_15px_rgba(225,29,72,0.4)] flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete User
                </button>
            </div>
        </div>
    </div>

<div id="suspensionDetailsModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-md bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
    <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-700 text-slate-400 flex items-center justify-center border border-slate-600 shadow-[0_0_10px_rgba(100,116,139,0.2)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <h2 class="text-lg font-extrabold text-white tracking-tight">Suspension Details</h2>
        </div>
        <button onclick="closeModal('suspensionDetailsModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
    </div>
    <div class="p-8 space-y-6">
        <div class="bg-slate-950/50 border border-slate-800 rounded-xl p-4 space-y-3">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">User</p>
                    <p class="text-white font-bold mt-1" id="detailsUserName">Name</p>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Ban Type</p>
                    <p class="text-amber-400 font-bold mt-1" id="detailsBanType">Type</p>
                </div>
            </div>
        </div>

        <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Reason for Suspension</label>
            <div class="bg-slate-950 border border-slate-800 rounded-xl p-4 text-slate-300 text-sm leading-relaxed" id="detailsReason">Reason text</div>
        </div>

        <div id="detailsDatesSection" class="space-y-4">
            <div id="detailsPermanentDates" class="hidden">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Suspended Since</label>
                <div class="bg-slate-950 border border-slate-800 rounded-xl p-4 flex items-center gap-2 text-slate-300">
                    <svg class="w-4 h-4 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <span class="font-mono text-sm" id="detailsSuspendedDate">Date</span>
                </div>
            </div>
            <div id="detailsTemporaryDates" class="hidden space-y-3">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Suspension Started</label>
                    <div class="bg-slate-950 border border-slate-800 rounded-xl p-4 flex items-center gap-2 text-slate-300">
                        <svg class="w-4 h-4 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span class="font-mono text-sm" id="detailsStartDate">Date</span>
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Will Be Lifted On</label>
                    <div class="bg-slate-950 border border-slate-800 rounded-xl p-4 flex items-center gap-2 text-emerald-400">
                        <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span class="font-mono text-sm font-bold" id="detailsEndDate">Date</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="pt-4 border-t border-slate-800">
            <button type="button" onclick="closeModal('suspensionDetailsModal')" class="w-full px-4 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold transition">Close</button>
        </div>
    </div>
</div>

<div id="liftSuspensionModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-md bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
    <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-5h.01"></path></svg>
            </div>
            <h2 class="text-lg font-extrabold text-white tracking-tight">Lift Suspension</h2>
        </div>
        <button onclick="closeModal('liftSuspensionModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
    </div>
    <div class="p-8 space-y-6">
        <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4">
            <p class="text-slate-300 text-sm leading-relaxed">Are you sure you want to lift the suspension for <span class="font-bold text-emerald-400" id="liftUserName">user</span>? This will immediately restore their access to the platform.</p>
        </div>

        <div class="bg-slate-950/50 border border-slate-800 rounded-xl p-4">
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Suspension Type</p>
            <p class="text-amber-400 font-bold" id="liftBanType">TEMPORARY</p>
        </div>

        <p id="liftError" class="text-rose-500 text-xs hidden text-center"></p>
        <p id="liftSuccess" class="text-emerald-500 text-xs hidden text-center"></p>

        <input type="hidden" id="liftUserId">

        <div class="flex gap-3 pt-4 border-t border-slate-800">
            <button type="button" onclick="closeModal('liftSuspensionModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
            <button type="button" onclick="confirmLiftSuspension()" class="flex-1 px-4 py-3 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-bold transition shadow-[0_0_15px_rgba(16,185,129,0.4)]">Yes, Restore Access</button>
        </div>
    </div>
</div>

<div id="suspensionModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-lg bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
    <div class="px-8 pt-8 pb-4 bg-slate-900 flex flex-col gap-2">
        <div class="flex items-center gap-3 mb-1">
            <div class="w-8 h-8 rounded-full bg-orange-500/10 text-orange-500 flex items-center justify-center border border-orange-500/20 shadow-[0_0_10px_rgba(234,88,12,0.2)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
            </div>
            <h2 class="text-xl font-extrabold text-white tracking-tight">Suspend Account</h2>
        </div>
        <p class="text-sm text-slate-400">Select the penalty action for <span id="suspensionUserName" class="font-bold text-white">User Name Here</span>.</p>
    </div>
    
    <div class="px-8 pb-8 space-y-6">
        <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Penalty Type</label>
            <div class="grid grid-cols-2 gap-4">
                
                <label for="suspensionTypeTemp" class="relative flex flex-col p-4 rounded-xl border border-slate-700 bg-slate-950/50 cursor-pointer hover:border-slate-600 transition has-[:checked]:border-blue-500 has-[:checked]:bg-blue-500/10 has-[:checked]:hover:bg-blue-500/20 group" onclick="updateSuspensionFields()">
                    <input type="radio" id="suspensionTypeTemp" name="suspensionType" value="temporary" class="sr-only" checked>
                    <div class="absolute top-3 right-3 hidden has-[:checked]:block text-blue-400">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    </div>
                    <div class="flex items-center gap-2 mb-2">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="font-bold text-white text-sm">Temporary</span>
                    </div>
                    <p class="text-xs text-slate-400 leading-relaxed">Account is suspended until a specific date.</p>
                </label>

                <label for="suspensionTypePerm" class="relative flex flex-col p-4 rounded-xl border border-slate-700 bg-slate-950/50 cursor-pointer hover:border-slate-600 transition has-[:checked]:border-rose-500 has-[:checked]:bg-rose-500/10 has-[:checked]:hover:bg-rose-500/20" onclick="updateSuspensionFields()">
                    <input type="radio" id="suspensionTypePerm" name="suspensionType" value="permanent" class="sr-only">
                    <div class="absolute top-3 right-3 hidden has-[:checked]:block text-rose-500">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    </div>
                    <div class="flex items-center gap-2 mb-2">
                        <svg class="w-4 h-4 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
                        <span class="font-bold text-white text-sm">Permanent Ban</span>
                    </div>
                    <p class="text-xs text-slate-400 leading-relaxed">Account is indefinitely blocked from the system.</p>
                </label>
            </div>
        </div>

        <div id="tempDateField">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Lift Suspension On</label>
            <input type="date" id="suspensionUntilDate" class="w-full bg-slate-950 border border-slate-700 text-slate-300 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20 transition shadow-inner [color-scheme:dark] [&::-webkit-calendar-picker-indicator]:opacity-50 [&::-webkit-calendar-picker-indicator]:hover:opacity-100 [&::-webkit-calendar-picker-indicator]:cursor-pointer">        </div>

        <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Reason for Action</label>
            <textarea id="suspensionReason" class="w-full bg-slate-950 border border-slate-700 text-slate-300 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20 transition shadow-inner resize-none placeholder-slate-600" placeholder="Provide a detailed reason..." rows="3"></textarea>
        </div>

        <p id="suspensionError" class="text-rose-500 text-xs hidden text-center"></p>
        <p id="suspensionSuccess" class="text-emerald-500 text-xs hidden text-center"></p>

        <input type="hidden" id="suspensionUserId">

        <div class="flex justify-end gap-3 pt-4 border-t border-slate-800">
            <button type="button" onclick="closeModal('suspensionModal'); resetSuspensionForm()" class="px-6 py-2.5 rounded-xl border border-slate-700 text-slate-300 text-sm font-bold hover:bg-slate-800 transition">Cancel</button>
            <button type="button" id="suspensionSubmitBtn" onclick="confirmSuspension()" class="px-6 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold transition shadow-[0_0_15px_rgba(37,99,235,0.4)]">Apply Suspension</button>
        </div>
    </div>
</div>

    <div id="verificationModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-md bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h2 class="text-lg font-extrabold text-white tracking-tight">Verify Account</h2>
        </div>
        
        <div class="p-8 space-y-6">
            <div class="text-center space-y-2 mb-6">
                <p class="text-slate-300 text-sm font-medium">A 6-digit verification code has been sent to</p>
                <p id="verificationEmail" class="text-emerald-400 font-bold text-sm font-mono break-all">email@example.com</p>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Verification Code</label>
                <div class="flex gap-2 justify-center">
                    <input type="text" id="verifyDigit1" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit2" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit3" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit4" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit5" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit6" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                </div>
            </div>

            <p id="verificationError" class="text-rose-500 text-xs hidden text-center"></p>
            <p id="verificationSuccess" class="text-emerald-500 text-xs hidden text-center"></p>

            <div class="text-center text-xs text-slate-500">
                <p>Didn't receive code? <span class="text-emerald-400 font-bold cursor-pointer hover:text-emerald-300">Resend</span></p>
            </div>

            <div class="flex gap-3">
                <button type="button" onclick="closeModal('verificationModal'); resetVerificationCode()" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="submitVerificationCode()" class="flex-1 px-4 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-extrabold transition shadow-[0_0_15px_rgba(52,211,153,0.4)]">Verify</button>
            </div>
        </div>
    </div>

    <script src="/js/admin/adminUsers.js"></script>

</body>
</html>