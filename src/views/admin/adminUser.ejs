            <div class="bg-red-900/10 border border-red-500/30 rounded-lg p-4 mb-6">
                <p class="text-sm text-gray-300 mb-2">Are you sure you want to delete this user?</p>
                <p class="text-sm font-bold text-white" id="deleteUserName">User Name</p>
                <p class="text-xs text-gray-500 mt-2">This action cannot be undone. All user data, including assignment history and activity logs, will be permanently removed.</p>
            </div>

            <!-- Error/Success Messages -->
            <p id="deleteFormError" class="text-red-500 text-sm mb-4"></p>
            <p id="deleteFormSuccess" class="text-green-500 text-sm mb-4"></p>

            <!-- Footer Buttons -->
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('deleteUserModal')" class="flex-1 px-4 py-2.5 border border-gray-600 text-gray-300 font-bold rounded-lg hover:bg-gray-800 hover:text-white transition">Cancel</button>
                <button type="button" onclick="confirmDeleteUser()" class="flex-1 px-4 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-500 transition shadow-lg shadow-red-900/20 flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete User
                </button>
            </div>
        </div>
    </div>

    <!-- DELETE ASSIGNMENT CONFIRMATION MODAL -->
    <div id="deleteAssignmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal('deleteAssignmentModal')"></div>
        <div class="relative bg-[#111827] border border-gray-700 w-full max-w-md rounded-xl shadow-2xl p-6 transform transition-all duration-300 modal-content-enter modal-content">
            <!-- Modal Header -->
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <div class="w-10 h-10 rounded-full bg-red-900/30 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                    </div>
                    Cancel Assignment
                </h2>
                <button onclick="closeModal('deleteAssignmentModal')" class="text-gray-400 hover:text-white transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Hidden Assignment ID -->
            <input type="hidden" id="deleteAssignmentId">

            <!-- Warning Message -->
            <div class="bg-red-900/10 border border-red-500/30 rounded-lg p-4 mb-6">
                <p class="text-sm text-gray-300 mb-2">Are you sure you want to cancel this assignment?</p>
                <p class="text-sm font-bold text-white" id="deleteAssignmentDriverName">Driver Name</p>
                <p class="text-xs text-gray-400 mt-1" id="deleteAssignmentVehicle">Vehicle Info</p>
                <p class="text-xs text-gray-500 mt-2">This will remove the driver's current task and set them back to available status.</p>
            </div>

            <!-- Error/Success Messages -->
            <p id="deleteAssignmentError" class="text-red-500 text-sm mb-4"></p>
            <p id="deleteAssignmentSuccess" class="text-green-500 text-sm mb-4"></p>

            <!-- Footer Buttons -->
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('deleteAssignmentModal')" class="flex-1 px-4 py-2.5 border border-gray-600 text-gray-300 font-bold rounded-lg hover:bg-gray-800 hover:text-white transition">Keep Assignment</button>
                <button type="button" onclick="confirmDeleteAssignment()" class="flex-1 px-4 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-500 transition shadow-lg shadow-red-900/20 flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                    Cancel Assignment
                </button>
            </div>
        </div>
    </div>

    <!-- EDIT ASSIGNMENT MODAL -->
    <div id="editAssignmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal('editAssignmentModal')"></div>
        <div class="relative bg-[#111827] border border-gray-700 w-full max-w-2xl rounded-xl shadow-2xl p-0 transform transition-all duration-300 modal-content-enter modal-content flex flex-col max-h-[90vh]">
            
            <!-- Header -->
            <div class="flex justify-between items-center p-6 border-b border-gray-800">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <div class="p-2 bg-blue-900/30 rounded-lg">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    </div>
                    Edit Assignment
                </h2>
                <button onclick="closeModal('editAssignmentModal')" class="text-gray-400 hover:text-white transition p-2 hover:bg-gray-800 rounded-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Scrollable Content -->
            <div class="overflow-y-auto flex-1 p-6 custom-scrollbar">
                <form id="editAssignmentForm" class="space-y-5" onsubmit="event.preventDefault();">
                    
                    <!-- Hidden Assignment ID -->
                    <input type="hidden" id="editAssignmentId">
                    
                    <!-- Error/Success Messages -->
                    <p id="editAssignmentError" class="text-red-500 text-sm"></p>
                    <p id="editAssignmentSuccess" class="text-green-500 text-sm"></p>

                    <!-- Driver Info (Read-only) -->
                    <div class="bg-gray-800/50 rounded-lg p-4 border border-gray-700">
                        <p class="text-[10px] text-gray-500 uppercase font-bold mb-1">Driver</p>
                        <p id="editAssignmentDriver" class="text-sm font-bold text-white">Driver Name</p>
                    </div>

                    <!-- Vehicle Number Input -->
                    <div>
                        <label class="block text-xs text-gray-400 font-bold mb-2">Vehicle Number</label>
                        <div class="flex">
                            <span class="inline-flex items-center px-4 bg-gray-700 border border-r-0 border-gray-600 rounded-l-lg text-gray-300 text-sm font-bold">RC-</span>
                            <input type="text" id="editAssignmentVehicle" placeholder="0001" maxlength="4"
                                class="flex-1 bg-[#1F2937] border border-gray-700 text-sm rounded-r-lg px-4 py-3 focus:outline-none focus:border-blue-400 text-white font-mono">
                        </div>
                    </div>

                    <!-- Status Selection -->
                    <div>
                        <label class="block text-xs text-gray-400 font-bold mb-2">Assignment Status</label>
                        <select id="editAssignmentStatus" class="w-full bg-[#1F2937] border border-gray-700 text-sm rounded-lg px-4 py-3 focus:outline-none focus:border-blue-400 text-white">
                            <option value="active">Active (In Transit)</option>
                            <option value="pending">Pending</option>
                            <option value="completed">Completed</option>
                        </select>
                    </div>

                    <!-- Map for editing pickup/destination -->
                    <div>
                        <label class="block text-xs text-gray-400 font-bold mb-2">Route (Click map to update locations)</label>
                        
                        <!-- Mode Indicator -->
                        <div class="flex items-center gap-2 mb-2">
                            <span id="editModeDot" class="w-2 h-2 rounded-full bg-[#2DD4BF] animate-pulse"></span>
                            <span id="editModeText" class="text-xs font-bold text-[#2DD4BF]">Set Pickup Point</span>
                        </div>

                        <!-- Coordinate Inputs -->
                        <div class="grid grid-cols-2 gap-4 mb-3">
                            <div class="relative" id="editPickupInputWrapper">
                                <input type="text" id="editPickupInput" placeholder="Click map for pickup..." readonly
                                    onclick="setEditMapMode('pickup')"
                                    class="w-full bg-[#1F2937] border border-gray-700 text-sm rounded-lg pl-10 pr-4 py-3 focus:outline-none text-white cursor-pointer">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-[#2DD4BF]"></span>
                            </div>
                            <div class="relative" id="editDestInputWrapper">
                                <input type="text" id="editDestInput" placeholder="Click map for destination..." readonly
                                    onclick="setEditMapMode('dest')"
                                    class="w-full bg-[#1F2937] border border-gray-700 text-sm rounded-lg pl-10 pr-4 py-3 focus:outline-none text-white cursor-pointer">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-red-500"></span>
                            </div>
                        </div>

                        <!-- Trip Stats (shown after route calculated) -->
                        <div id="editTripStats" class="hidden mb-3 grid grid-cols-2 gap-3">
                            <div class="bg-gray-800/50 rounded-lg p-3 flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-blue-900/30 flex items-center justify-center">
                                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </div>
                                <div>
                                    <p class="text-[10px] text-gray-500 uppercase">Duration</p>
                                    <p id="editTimeVal" class="text-sm font-bold text-white">--</p>
                                </div>
                            </div>
                            <div class="bg-gray-800/50 rounded-lg p-3 flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center">
                                    <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                </div>
                                <div>
                                    <p class="text-[10px] text-gray-500 uppercase">Distance</p>
                                    <p id="editDistVal" class="text-sm font-bold text-white">--</p>
                                </div>
                            </div>
                        </div>

                        <!-- Map Container -->
                        <div id="editAssignmentMap" class="w-full h-64 rounded-lg border border-gray-700 overflow-hidden"></div>
                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="p-6 border-t border-gray-800 flex gap-3">
                <button type="button" onclick="closeModal('editAssignmentModal')" class="flex-1 px-4 py-2.5 border border-gray-600 text-gray-300 font-bold rounded-lg hover:bg-gray-800 hover:text-white transition">Cancel</button>
                <button type="button" onclick="saveAssignmentChanges()" class="flex-1 px-4 py-2.5 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-500 transition shadow-lg shadow-blue-900/20 flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>

    <!-- Leaflet & App JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Leaflet Routing Machine for route calculation -->
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.min.js"></script>
    <script src="/js/admin/adminUsers.js"></script>

</body>
</html>
