                                                    <div class="font-bold text-white text-sm" data-field="name">Sarah Johnson</div>
                                                    <div class="text-xs text-slate-500 mt-0.5" data-field="email">sarah.johnson@example.com</div>
                                                </div>
                                            </div>
                                        </td>
