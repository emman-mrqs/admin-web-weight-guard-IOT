<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - User Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/admin/adminUsers.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden relative bg-slate-950">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 shrink-0 z-10 sticky top-0">
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">User Management</h1>
                <p class="text-xs text-slate-400 font-medium mt-0.5">Control permissions and platform access</p>
            </div>
            <div class="flex items-center gap-4">
                <a href="/admin/task-dispatch" class="bg-slate-800 border border-slate-700 text-white px-4 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-slate-700 transition shadow-sm">
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    TASK DISPATCH
                </a>
                <button onclick="openModal('addUserModal')" class="bg-emerald-500 text-slate-900 px-4 py-2.5 rounded-xl text-xs font-extrabold flex items-center gap-2 hover:bg-emerald-400 transition shadow-[0_0_15px_rgba(52,211,153,0.4)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                    ADD NEW USER
                </button>
            </div>
        </header>

        <div class="flex-1 overflow-hidden p-8 flex flex-col space-y-6">
            
            <div id="summaryStats" class="grid grid-cols-4 gap-6 shrink-0">
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4">
                    <div class="p-3 bg-blue-500/10 border border-blue-500/20 rounded-xl text-blue-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Total Users</p>
                        <p id="summaryTotalUsers" class="text-2xl font-extrabold text-white leading-none">142</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
                    <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Active Drivers</p>
                        <p id="summaryActiveUsers" class="text-2xl font-extrabold text-white leading-none">114</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.5)]"></div>
                    <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-amber-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Unassigned</p>
                        <p id="summaryUnassigned" class="text-2xl font-extrabold text-white leading-none">24</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]"></div>
                    <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl text-rose-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Suspended</p>
                        <p id="summarySuspendedUsers" class="text-2xl font-extrabold text-rose-400 leading-none">4</p>
                    </div>
                </div>
            </div>

            <div class="flex-1 overflow-hidden relative">
    
                <div id="listView" class="flex flex-col h-full absolute inset-0 transition-opacity duration-300">
                    <div class="bg-slate-900 rounded-t-2xl border border-slate-800 border-b-0 shadow-lg p-5 px-6 flex flex-col md:flex-row gap-4 justify-between items-center shrink-0">
                        <div class="relative w-full md:w-96 group">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none">
                                <svg class="w-4 h-4 text-slate-500 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </span>
                            <input type="text" placeholder="Search by name or email..." class="w-full bg-slate-950 border border-slate-700 text-sm rounded-xl pl-10 pr-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 text-slate-200 transition-all placeholder-slate-500 shadow-inner">
                        </div>
                        <div class="flex gap-3 w-full md:w-auto">
                            <select class="bg-slate-950 border border-slate-700 text-xs font-bold text-slate-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-emerald-500 appearance-none shadow-inner cursor-pointer flex-1">
                                <option>All Assignments</option>
                                <option>In Transit</option>
                                <option>Idle</option>
                                <option>Unassigned</option>
                            </select>
                            <select class="bg-slate-950 border border-slate-700 text-xs font-bold text-slate-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-emerald-500 appearance-none shadow-inner cursor-pointer flex-1">
                                <option>All Status</option>
                                <option>Active</option>
                                <option>Inactive</option>
                                <option>Pending</option>
                            </select>
                        </div>
                    </div>

                    <div class="bg-slate-900 rounded-b-2xl border border-slate-800 shadow-lg flex flex-col overflow-hidden flex-1">
                        <div class="overflow-y-auto custom-scrollbar h-full">
                            <table class="w-full text-left border-collapse whitespace-nowrap">
                                <thead class="sticky top-0 bg-slate-900/90 backdrop-blur border-b border-slate-800 z-10">
                                    <tr class="text-slate-500 text-[10px] uppercase tracking-widest font-bold">
                                        <th class="px-6 py-4">User</th>
                                        <th class="px-6 py-4">Assignment</th>
                                        <th class="px-6 py-4">Status</th>
                                        <th class="px-6 py-4">Created At</th>
                                        <th class="px-6 py-4 text-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody" class="divide-y divide-slate-800/50">
                                    <tr class="hover:bg-slate-800/40 transition-colors group">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 bg-slate-800 rounded-lg flex items-center justify-center border border-slate-700 text-slate-400 font-bold">
                                                    ML
                                                </div>
                                                <div>
                                                    <div class="font-bold text-white text-sm">Marcus Lee</div>
                                                    <div class="text-xs text-slate-500 mt-0.5">marcus@weighguard.io</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="text-sm font-bold text-slate-300">Trailer Truck</div>
                                            <div class="font-mono text-[10px] text-slate-500 mt-0.5">RC-8802</div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold tracking-wide">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                                                ACTIVE
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-xs text-slate-400 font-medium">
                                            Oct 12, 2025
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-1">
                                                <button onclick="toggleModal('historyModal')" class="text-slate-500 hover:text-emerald-400 transition p-2 rounded-lg hover:bg-slate-800/80" title="View History"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg></button>
                                                <button onclick="toggleModal('editUserModal')" class="text-slate-500 hover:text-blue-400 transition p-2 rounded-lg hover:bg-slate-800/80" title="Edit User"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg></button>
                                                <button onclick="toggleModal('deleteUserModal')" class="text-slate-500 hover:text-rose-400 transition p-2 rounded-lg hover:bg-slate-800/80" title="Delete User"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                        
                        <div class="p-4 px-6 border-t border-slate-800 bg-slate-900/50 flex items-center justify-between">
                            <p class="text-xs text-slate-500 font-medium" id="pagination-info">
                                Showing <span class="text-white font-bold">1</span> to <span class="text-white font-bold">10</span> of <span class="text-white font-bold">142</span> entries
                            </p>
                            <div class="flex items-center gap-1.5" id="pagination-controls">
                                <button class="p-2 rounded-lg border border-slate-700 text-slate-400 opacity-50 cursor-not-allowed bg-slate-800/50"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg></button>
                                <button class="w-8 h-8 flex items-center justify-center rounded-lg border bg-emerald-500/10 border-emerald-500/30 text-emerald-400 text-xs font-bold">1</button>
                                <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-700 text-slate-400 hover:bg-slate-800 hover:text-white transition text-xs font-bold">2</button>
                                <button class="p-2 rounded-lg border border-slate-700 text-slate-400 hover:bg-slate-800 hover:text-white transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <div id="modalOverlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300" onclick="closeAllModals()"></div>

    <div id="addUserModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-2xl bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(52,211,153,0.2)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                </div>
                <h2 class="text-xl font-extrabold text-white tracking-tight">Add New User</h2>
            </div>
            <button onclick="closeModal('addUserModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
        <form id="addUserForm" class="p-8 space-y-6">
            <p id="formError" class="text-rose-500 text-sm hidden"></p>
            <p id="formSuccess" class="text-emerald-500 text-sm hidden"></p>
            
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">First Name</label>
                    <input type="text" name="firstName" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition shadow-inner" placeholder="John">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Last Name</label>
                    <input type="text" name="lastName" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition shadow-inner" placeholder="Doe">
                </div>
                <div class="col-span-2">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Email Address</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path></svg>
                        </span>
                        <input type="email" name="email" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition shadow-inner" placeholder="john.doe@weighguard.io">
                    </div>
                </div>
                <div class="col-span-2 grid grid-cols-2 gap-6 border-t border-slate-800 pt-6">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Password</label>
                        <div class="relative">
                            <input type="password" id="addPassword" name="password" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 pr-10 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition shadow-inner" placeholder="••••••••">
                            <button type="button" onclick="togglePasswordVisibility('addPassword', 'toggleAddPasswordIcon')" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500 hover:text-emerald-400 transition">
                                <svg id="toggleAddPasswordIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            </button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Confirm Password</label>
                        <div class="relative">
                            <input type="password" id="addConfirmPassword" name="confirmPassword" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 pr-10 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition shadow-inner" placeholder="••••••••">
                            <button type="button" onclick="togglePasswordVisibility('addConfirmPassword', 'toggleAddConfirmPasswordIcon')" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500 hover:text-emerald-400 transition">
                                <svg id="toggleAddConfirmPasswordIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Need a secure password?</span>
                <button type="button" onclick="generateRandomPassword()" class="text-xs font-bold text-emerald-400 border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5 rounded-lg hover:bg-emerald-500/20 transition flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Generate Random
                </button>
            </div>

            <div class="pt-4 border-t border-slate-800 flex gap-4 mt-2">
                <button type="button" onclick="closeModal('addUserModal')" class="w-1/3 py-3.5 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 hover:text-white transition">Cancel</button>
                <button type="submit" class="w-2/3 py-3.5 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-extrabold transition shadow-[0_0_15px_rgba(52,211,153,0.4)] tracking-wide uppercase text-xs">
                    Create User Account
                </button>
            </div>
        </form>
    </div>

    <div id="editUserModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-2xl bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-blue-500/10 text-blue-400 flex items-center justify-center border border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.2)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                </div>
                <h2 class="text-xl font-extrabold text-white tracking-tight">Edit User Details</h2>
            </div>
            <button onclick="closeModal('editUserModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
        
        <form id="editUserForm" class="p-8 space-y-6">
            <p id="editFormError" class="text-rose-500 text-sm hidden"></p>
            <p id="editFormSuccess" class="text-emerald-500 text-sm hidden"></p>
            <input type="hidden" id="editUserId" name="user_id">
            
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">First Name</label>
                    <input type="text" id="editFirstName" name="firstName" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-inner">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Last Name</label>
                    <input type="text" id="editLastName" name="lastName" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-inner">
                </div>
                <div class="col-span-2">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Email Address (Read Only)</label>
                    <input type="email" id="editEmail" name="email" class="w-full bg-slate-900 border border-slate-800 text-slate-500 text-sm rounded-xl px-4 py-3.5 cursor-not-allowed shadow-inner font-mono" readonly>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-6 border-t border-slate-800 pt-6">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Account Status</label>
                    <div class="relative">
                        <select id="editStatus" name="status" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 appearance-none cursor-pointer shadow-inner">
                            <option value="active">Active Account</option>
                            <option value="inactive">Inactive (Suspended)</option>
                            <option value="pending">Pending Approval</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Vehicle Assignment</label>
                    <div class="relative">
                        <select id="editVehicle" name="vehicle" class="w-full bg-slate-950 border border-slate-700 text-slate-300 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 appearance-none cursor-pointer shadow-inner">
                            <option value="">Unassigned</option>
                            <option value="RC-8802">Trailer Truck - RC-8802</option>
                            <option value="RC-0034">Reefer Truck - RC-0034</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-800 flex gap-4 mt-2">
                <button type="button" onclick="closeModal('editUserModal')" class="w-1/3 py-3.5 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 hover:text-white transition">Cancel</button>
                <button type="submit" class="w-2/3 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-extrabold transition shadow-[0_0_15px_rgba(37,99,235,0.4)] tracking-wide uppercase text-xs">
                    Save Changes
                </button>
            </div>
        </form>
    </div>

    <div id="historyModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-4xl bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-extrabold text-white flex items-center gap-2 tracking-tight">
                    <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    </div>
                    Activity Log
                </h2>
                <p class="text-xs text-slate-400 mt-1 ml-10">Detailed history of user activity and assignments.</p>
            </div>
            <button onclick="closeModal('historyModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
        
        <div class="max-h-[50vh] overflow-auto custom-scrollbar">
            <table class="w-full text-left whitespace-nowrap">
                <thead class="sticky top-0 bg-slate-900/90 backdrop-blur border-b border-slate-800 z-10">
                    <tr class="text-slate-500 text-[10px] uppercase tracking-widest font-bold">
                        <th class="px-6 py-4">Timestamp</th>
                        <th class="px-6 py-4">Action</th>
                        <th class="px-6 py-4">Details</th>
                        <th class="px-6 py-4">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50 bg-slate-900">
                    <tr class="hover:bg-slate-800/40 transition">
                        <td class="px-6 py-4 text-xs text-white">May 12, 08:30 AM</td>
                        <td class="px-6 py-4 text-xs text-slate-300 font-bold">Assignment Started</td>
                        <td class="px-6 py-4 text-xs text-slate-400 font-mono">RC-8802 (Warehouse A -> Zone B)</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold tracking-wide">ACTIVE</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="deleteUserModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-sm bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300">
        <div class="p-6 text-center space-y-4">
            <div class="w-16 h-16 bg-rose-500/10 border border-rose-500/30 rounded-full flex items-center justify-center mx-auto text-rose-500 mb-2 shadow-[0_0_15px_rgba(244,63,94,0.2)]">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-white tracking-tight">Delete User Account?</h2>
            
            <input type="hidden" id="deleteUserId">

            <div class="bg-rose-950/20 border border-rose-500/20 rounded-xl p-4 mb-2 text-left">
                <p class="text-xs text-slate-400 uppercase tracking-widest font-bold mb-1">Target User</p>
                <p class="text-sm font-bold text-white mb-2" id="deleteUserName">User Name Here</p>
                <p class="text-[10px] text-slate-500 leading-relaxed">This action cannot be undone. All user data, assignment history, and login access will be permanently wiped.</p>
            </div>

            <p id="deleteFormError" class="text-rose-500 text-xs hidden"></p>
            <p id="deleteFormSuccess" class="text-emerald-500 text-xs hidden"></p>

            <div class="pt-4 flex gap-3">
                <button type="button" onclick="closeModal('deleteUserModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="confirmDeleteUser()" class="flex-1 px-4 py-3 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-bold transition shadow-[0_0_15px_rgba(225,29,72,0.4)] flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete User
                </button>
            </div>
        </div>
    </div>

    <script src="/js/admin/adminUsers.js"></script>

</body>
</html>