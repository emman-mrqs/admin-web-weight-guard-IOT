<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Task Dispatch</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    <link rel="stylesheet" href="/css/admin/adminUsers.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">
    
    <%- include('../partials/adminHeaderSidebar', { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden relative bg-slate-950">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 shrink-0 z-10 sticky top-0">
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">Task Dispatch Center</h1>
                <p class="text-xs text-slate-400 font-medium mt-0.5">Assign routes and manage dispatch operations</p>
            </div>
            <div class="flex items-center gap-4">
                <a href="/admin/users" class="bg-slate-800 border border-slate-700 text-white px-4 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-slate-700 transition shadow-sm">
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    USER MANAGEMENT
                </a>
                <button onclick="openAssignTaskModal()" class="bg-emerald-500 text-slate-900 px-4 py-2.5 rounded-xl text-xs font-extrabold flex items-center gap-2 hover:bg-emerald-400 transition shadow-[0_0_15px_rgba(52,211,153,0.4)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    ASSIGN TASK
                </button>
            </div>
        </header>

        <div class="flex-1 overflow-hidden p-8 flex gap-6">
            
            <div class="w-1/4 bg-slate-900 rounded-2xl border border-slate-800 shadow-lg flex flex-col overflow-hidden shrink-0">
                <div class="p-5 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
                    <div>
                        <h3 class="text-white font-bold text-sm tracking-wide">Active Assignments</h3>
                        <p class="text-[10px] text-slate-500 mt-0.5 uppercase tracking-widest font-bold">Select to view route</p>
                    </div>
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                </div>
                <div id="assignmentsList" class="flex-1 overflow-y-auto custom-scrollbar p-3 space-y-2">
                    <div class="p-8 text-center text-slate-500 text-xs flex flex-col items-center">
                        <svg class="w-8 h-8 mb-3 text-slate-600 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        Loading assignments...
                    </div>
                </div>
                <div class="px-3 py-3 border-t border-slate-800 bg-slate-900/60 flex items-center justify-between">
                    <p id="assignmentsPaginationInfo" class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Showing 0 to 0 of 0</p>
                    <div id="assignmentsPaginationControls" class="flex items-center gap-1.5"></div>
                </div>
            </div>

            <div class="flex-1 flex flex-col gap-6">
                
                <div id="dispatchMapCard" class="flex-1 bg-slate-900 rounded-2xl overflow-hidden relative border border-slate-800 shadow-lg">
                    <div id="users-map" class="w-full h-full z-0"></div>

                    <div class="absolute top-4 left-4 z-10 bg-slate-900/90 backdrop-blur-md p-4 rounded-xl border border-slate-700/50 shadow-xl pointer-events-none">
                        <p class="font-bold text-white text-xs uppercase tracking-widest mb-3">Route Legend</p>
                        <div class="space-y-2 text-xs">
                            <div class="flex items-center gap-3">
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_5px_rgba(52,211,153,0.8)]"></span>
                                <span class="text-slate-300">Pickup Point</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-2.5 h-2.5 rounded-full bg-rose-500 shadow-[0_0_5px_rgba(244,63,94,0.8)]"></span>
                                <span class="text-slate-300">Destination</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-6 h-0.5 bg-blue-500 rounded shadow-[0_0_5px_rgba(59,130,246,0.8)]"></span>
                                <span class="text-slate-300">Route Path</span>
                            </div>
                        </div>
                    </div>

                    <button onclick="loadMapAssignments()" class="absolute top-4 right-4 z-10 bg-slate-900/90 hover:bg-slate-800 backdrop-blur-md p-3 rounded-xl border border-slate-700/50 text-slate-400 hover:text-white transition shadow-xl" title="Refresh Map Data">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    </button>
                    
                </div>

                <div id="dispatchTaskTableCard" class="hidden bg-slate-900 rounded-2xl border border-slate-800 p-5 shadow-lg shrink-0">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-extrabold text-white tracking-wide">Dispatch Task Table</h3>
                        <span class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Latest Assignments</span>
                    </div>
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="w-full min-w-[700px] text-xs">
                            <thead>
                                <tr class="text-slate-400 uppercase tracking-widest text-[10px] border-b border-slate-800">
                                    <th class="text-left py-3 pr-4">Driver</th>
                                    <th class="text-left py-3 pr-4">Vehicle</th>
                                    <th class="text-left py-3 pr-4">Status</th>
                                    <th class="text-left py-3 pr-4">Distance</th>
                                    <th class="text-left py-3 pr-4">Duration</th>
                                    <th class="text-left py-3 pr-4">Created By</th>
                                    <th class="text-left py-3 pr-0">Action</th>
                                </tr>
                            </thead>
                            <tbody id="dispatchTaskTableBody" class="divide-y divide-slate-800/60">
                                <tr>
                                    <td colspan="7" class="py-5 text-center text-slate-500 text-xs">Select an active assignment to view dispatch data.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="selectedTaskDetails" class="hidden bg-slate-900 rounded-2xl border border-slate-800 p-5 shadow-lg shrink-0">
                    
                    <div class="flex items-center justify-between mb-5">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-inner">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                            </div>
                            <div>
                                <p id="selectedDriverName" class="text-sm font-extrabold text-white tracking-wide">Driver Name</p>
                                <p id="selectedVehicle" class="text-[10px] text-slate-500 font-mono mt-0.5">#RC-0000</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button onclick="openEditAssignmentModal()" class="p-2 rounded-lg border border-slate-700 text-slate-400 bg-slate-900/40 transition hover:bg-blue-900/20 hover:border-blue-500/30 hover:text-blue-300" title="Edit Route">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            </button>
                            <button onclick="openDeleteAssignmentModal()" class="p-2 rounded-lg border border-slate-700 text-slate-400 bg-slate-900/40 transition hover:bg-red-900/20 hover:border-red-500/30 hover:text-red-300" title="Cancel Assignment">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                            <button onclick="hideTaskDetails()" class="text-slate-500 hover:text-white transition p-2 hover:bg-slate-800 rounded-lg" title="Close Panel">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                            </button>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                        <div class="bg-slate-950 rounded-xl p-3 border border-slate-800">
                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-1">Distance</p>
                            <p id="selectedDistance" class="text-sm font-bold text-white font-mono">-- km</p>
                        </div>
                        <div class="bg-slate-950 rounded-xl p-3 border border-slate-800">
                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-1">Duration</p>
                            <p id="selectedDuration" class="text-sm font-bold text-white font-mono">-- min</p>
                        </div>
                        <div class="bg-slate-950 rounded-xl p-3 border border-slate-800">
                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-1">Status</p>
                            <p id="selectedStatus" class="text-sm font-bold text-emerald-400">Active</p>
                        </div>
                        <div class="bg-slate-950 rounded-xl p-3 border border-slate-800">
                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-1">Dispatched</p>
                            <p id="selectedStartTime" class="text-sm font-bold text-white font-mono">--:--</p>
                        </div>
                    </div>

                    <div id="mapRouteDirections" class="hidden mt-4 border-t border-slate-800 pt-4">
                        <div class="bg-slate-950 border border-slate-800 rounded-xl overflow-hidden">
                            <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                    <span class="text-xs font-bold text-white uppercase tracking-widest">Turn-by-Turn Route</span>
                                </div>
                                <span id="mapRouteSummary" class="text-[10px] text-slate-500 font-mono"></span>
                            </div>
                            <div id="mapDirectionsContent" class="block">
                                <div class="max-h-64 md:max-h-72 overflow-y-auto custom-scrollbar">
                                    <ul id="mapDirectionsList" class="divide-y divide-slate-800/50 text-sm"></ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <div id="assignTaskModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="closeAssignTaskModal()"></div>
        
        <div class="relative bg-slate-900 border border-slate-700/50 w-full max-w-4xl rounded-2xl shadow-2xl p-0 transform transition-all duration-300 flex flex-col max-h-[90vh] overflow-hidden modal-content-enter modal-content">
            
            <div class="flex justify-between items-center px-8 py-6 border-b border-slate-800 bg-slate-900/50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(52,211,153,0.2)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    </div>
                    <h2 class="text-xl font-extrabold text-white tracking-tight">Assign New Task</h2>
                </div>
                <button onclick="closeAssignTaskModal()" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>

            <div class="overflow-y-auto flex-1 p-8 custom-scrollbar">
                <form id="assignTaskForm" class="space-y-6" onsubmit="event.preventDefault();">
                    <p id="taskFormError" class="text-rose-500 text-sm font-bold hidden"></p>
                    <p id="taskFormSuccess" class="text-emerald-500 text-sm font-bold hidden"></p>

                    <div class="grid grid-cols-1 gap-6">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Assign Vehicle</label>
                            <div class="relative">
                                <select id="taskVehicleSelect" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 appearance-none transition shadow-inner cursor-pointer">
                                    <option value="">Choose an available vehicle...</option>
                                    <% (initialVehicles || []).forEach((vehicle) => { %>
                                        <option value="<%= vehicle.id %>">
                                            <%= `${vehicle.plate_number || ''} • ${vehicle.vehicle_type || 'Vehicle'} • ${(vehicle.first_name ? `${vehicle.first_name || ''} ${vehicle.last_name || ''}`.trim() : 'Unassigned')}` %>
                                        </option>
                                    <% }); %>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-slate-500">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-slate-800 pt-6">
                        <div class="flex justify-between items-center mb-4">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">Routing Configuration</label>
                            <span class="text-[10px] text-slate-500 bg-slate-950 border border-slate-800 px-3 py-1 rounded-full uppercase tracking-widest font-bold">Click map to plot</span>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div class="relative group">
                                <label class="block text-[10px] font-bold text-emerald-400 uppercase mb-2 flex items-center gap-2 tracking-widest">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_5px_rgba(52,211,153,0.8)]"></span> Pickup (A)
                                </label>
                                <input type="text" id="pickupInput" onclick="setTaskMode('pickup')" onkeypress="handleMapSearch(event, 'pickup', 'assign')" class="w-full bg-slate-950 border border-emerald-500/50 text-white text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none cursor-pointer transition shadow-inner font-mono hover:bg-slate-800" placeholder="Type address & press Enter...">
                                <div class="absolute left-3.5 top-[34px] text-emerald-400">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                </div>
                            </div>

                            <div class="relative group">
                                <label class="block text-[10px] font-bold text-rose-400 uppercase mb-2 flex items-center gap-2 tracking-widest">
                                    <span class="w-1.5 h-1.5 rounded-full bg-rose-400 shadow-[0_0_5px_rgba(244,63,94,0.8)]"></span> Destination (B)
                                </label>
                                <input type="text" id="destInput" onclick="setTaskMode('dest')" onkeypress="handleMapSearch(event, 'dest', 'assign')" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 cursor-pointer transition shadow-inner font-mono hover:bg-slate-800" placeholder="Type address & press Enter...">
                                <div class="absolute left-3.5 top-[34px] text-rose-400">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                </div>
                            </div>
                        </div>

                        <div id="tripStats" class="hidden grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                            <div class="bg-slate-950 rounded-xl p-3 border border-slate-800 flex items-center gap-3">
                                <div class="p-2 rounded-lg bg-blue-500/10 text-blue-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                                <div><p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Duration</p><p id="timeVal" class="text-sm font-bold text-white font-mono">--</p></div>
                            </div>
                            <div class="bg-slate-950 rounded-xl p-3 border border-slate-800 flex items-center gap-3">
                                <div class="p-2 rounded-lg bg-emerald-500/10 text-emerald-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg></div>
                                <div><p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Distance</p><p id="distVal" class="text-sm font-bold text-white font-mono">--</p></div>
                            </div>
                        </div>

                        <div class="relative w-full h-80 bg-slate-900 rounded-2xl overflow-hidden border border-slate-700 shadow-inner group">
                            <div id="taskMap" class="w-full h-full z-10"></div>
                            
                            <div class="absolute top-4 left-1/2 -translate-x-1/2 z-[400] bg-slate-900/90 backdrop-blur-md border border-slate-700 px-4 py-2 rounded-full shadow-xl flex items-center gap-2">
                                <span id="modeDot" class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                <span id="modeText" class="text-xs font-bold text-slate-200 tracking-wide uppercase">Set Pickup Point</span>
                            </div>

                            <button type="button" onclick="resetTaskMap()" class="absolute bottom-4 right-4 z-[400] bg-slate-900/90 text-slate-300 border border-slate-700 p-2.5 rounded-xl shadow-xl hover:bg-slate-800 hover:text-white transition" title="Clear Map">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="px-8 py-5 border-t border-slate-800 bg-slate-900/50 flex gap-4">
                <button type="button" onclick="closeAssignTaskModal()" class="w-1/3 py-3.5 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 hover:text-white transition">
                    Cancel
                </button>
                <button type="button" onclick="dispatchTask()" class="w-2/3 py-3.5 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-extrabold transition shadow-[0_0_15px_rgba(52,211,153,0.4)] flex items-center justify-center gap-2 tracking-wide uppercase text-xs rounded-xl">
                    <span>Dispatch Route</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
                </button>
            </div>
        </div>
    </div>

    <div id="deleteAssignmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal('deleteAssignmentModal')"></div>
        <div class="relative bg-slate-900 border border-slate-700/50 w-full max-w-md rounded-2xl shadow-2xl transition-all duration-300 overflow-hidden modal-content-enter modal-content">
            <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-rose-500/10 text-rose-400 flex items-center justify-center border border-rose-500/20 shadow-[0_0_10px_rgba(244,63,94,0.2)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </div>
                    <h2 class="text-lg font-extrabold text-white tracking-tight">Cancel Task Assignment?</h2>
                </div>
                <button onclick="closeModal('deleteAssignmentModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>

            <div class="p-8 space-y-6">
                <input type="hidden" id="deleteAssignmentId">

                <div class="bg-rose-950/20 border border-rose-500/20 rounded-xl p-4 text-left">
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Target Driver</p>
                    <p class="text-white font-bold mb-2" id="deleteAssignmentDriverName">Driver Name</p>
                    <p class="text-[10px] text-slate-500 font-mono mb-2" id="deleteAssignmentVehicle">Vehicle Info</p>
                    <p class="text-xs text-slate-400 leading-relaxed">This will remove the active route and set the driver back to idle.</p>
                </div>

                <p id="deleteAssignmentError" class="text-rose-500 text-xs hidden text-center"></p>
                <p id="deleteAssignmentSuccess" class="text-emerald-500 text-xs hidden text-center"></p>

                <div class="flex gap-3 pt-4 border-t border-slate-800">
                    <button type="button" onclick="closeModal('deleteAssignmentModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                    <button type="button" onclick="confirmDeleteAssignment()" class="flex-1 px-4 py-3 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-bold transition shadow-[0_0_15px_rgba(225,29,72,0.4)] flex justify-center items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        Cancel Task
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="editAssignmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-enter transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal('editAssignmentModal')"></div>
        <div class="relative bg-slate-900 border border-slate-700/50 w-full max-w-2xl rounded-2xl shadow-2xl p-0 transform transition-all duration-300 flex flex-col max-h-[90vh] overflow-hidden modal-content-enter modal-content">
            
            <div class="flex justify-between items-center px-8 py-6 border-b border-slate-800 bg-slate-900/50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-blue-500/10 text-blue-400 flex items-center justify-center border border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.2)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    </div>
                    <h2 class="text-xl font-extrabold text-white tracking-tight">Edit Assignment Details</h2>
                </div>
                <button onclick="closeModal('editAssignmentModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>

            <div class="overflow-y-auto flex-1 p-8 custom-scrollbar">
                <form id="editAssignmentForm" class="space-y-6" onsubmit="event.preventDefault();">
                    <input type="hidden" id="editAssignmentId">
                    <p id="editAssignmentError" class="text-rose-500 text-sm font-bold hidden"></p>
                    <p id="editAssignmentSuccess" class="text-emerald-500 text-sm font-bold hidden"></p>

                    <div class="bg-slate-950 rounded-xl p-4 border border-slate-800 shadow-inner flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-400">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest mb-0.5">Target Driver</p>
                            <p id="editAssignmentDriver" class="text-sm font-bold text-white">Driver Name</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6 border-t border-slate-800 pt-6">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Assign Vehicle</label>
                            <div class="relative">
                                <select id="editAssignmentVehicleSelect" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 appearance-none cursor-pointer transition shadow-inner">
                                    <option value="">Loading vehicles...</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-slate-500"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Assignment Status</label>
                            <div class="relative">
                                <select id="editAssignmentStatus" class="w-full bg-slate-950 border border-slate-700 text-white text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-blue-500 appearance-none cursor-pointer transition shadow-inner">
                                    <option value="pending">Pending Dispatch (Waiting)</option>
                                    <option value="active">Active (Accepted)</option>
                                    <option value="in_transit">In Transit</option>
                                    <option value="completed">Completed Route</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-slate-500"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></div>
                            </div>
                            <p id="editAssignmentStatusHint" class="mt-2 text-[10px] text-slate-500 font-medium">Pending can move forward. Active cannot return to Pending. In Transit cannot return to Pending or Active. Completed routes are final.</p>
                        </div>
                    </div>

                    <div class="border-t border-slate-800 pt-6">
                        <div class="flex justify-between items-center mb-4">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">Routing Configuration</label>
                            <div class="flex items-center gap-2">
                                <span id="editModeDot" class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                                <span id="editModeText" class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">Set Pickup Point</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div class="relative" id="editPickupInputWrapper">
                                <input type="text" id="editPickupInput" placeholder="Type address & press Enter..." onclick="setEditMapMode('pickup')" onkeypress="handleMapSearch(event, 'pickup', 'edit')" class="w-full bg-slate-950 border border-slate-700 text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-emerald-400 focus:ring-1 focus:ring-emerald-400 text-white cursor-pointer shadow-inner font-mono hover:bg-slate-800 transition">
                                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_5px_rgba(52,211,153,0.8)]"></span>
                            </div>
                            <div class="relative" id="editDestInputWrapper">
                                <input type="text" id="editDestInput" placeholder="Type address & press Enter..." onclick="setEditMapMode('dest')" onkeypress="handleMapSearch(event, 'dest', 'edit')" class="w-full bg-slate-950 border border-slate-700 text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-rose-400 focus:ring-1 focus:ring-rose-400 text-white cursor-pointer shadow-inner font-mono hover:bg-slate-800 transition">
                                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-rose-500 shadow-[0_0_5px_rgba(244,63,94,0.8)]"></span>
                            </div>
                        </div>

                        <div id="editTripStats" class="hidden mb-4 grid grid-cols-2 gap-4">
                            <div class="bg-slate-950 rounded-xl p-3 border border-slate-800 flex items-center gap-3">
                                <div class="p-2 rounded-lg bg-blue-500/10 text-blue-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                                <div><p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Duration</p><p id="editTimeVal" class="text-sm font-bold text-white font-mono">--</p></div>
                            </div>
                            <div class="bg-slate-950 rounded-xl p-3 border border-slate-800 flex items-center gap-3">
                                <div class="p-2 rounded-lg bg-emerald-500/10 text-emerald-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg></div>
                                <div><p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Distance</p><p id="editDistVal" class="text-sm font-bold text-white font-mono">--</p></div>
                            </div>
                        </div>

                        <div id="editAssignmentMap" class="w-full h-72 rounded-2xl border border-slate-700 overflow-hidden shadow-inner"></div>
                    </div>
                </form>
            </div>
            
            <div class="px-8 py-5 border-t border-slate-800 bg-slate-900/50 flex gap-3">
                <button type="button" onclick="closeModal('editAssignmentModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="saveAssignmentChanges()" class="flex-1 px-4 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold transition shadow-[0_0_15px_rgba(37,99,235,0.4)] flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.min.js"></script>
    <script src="/js/admin/adminDispatch.js"></script>
</body>
</html>