<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Add Vehicle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar', { currentPage: currentPage }) %>

    <main class="flex-1 flex relative overflow-hidden bg-slate-950">
        
        <div class="absolute top-8 left-8 z-20 pointer-events-auto flex items-center gap-4">
            <a href="/admin/fleet" class="p-2.5 bg-slate-900/80 hover:bg-slate-800 text-slate-400 hover:text-white rounded-xl border border-slate-700/50 backdrop-blur-md transition shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            </a>
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">Deploy New Vehicle</h1>
                <p class="text-xs text-slate-400 font-medium uppercase tracking-widest mt-1">3D Fleet Configurator</p>
            </div>
        </div>

        <div id="showroom-canvas" class="absolute inset-0 z-0 cursor-grab active:cursor-grabbing"></div>

        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex items-center gap-6 bg-slate-900/80 backdrop-blur-md px-6 py-3 rounded-2xl border border-slate-700/50 shadow-2xl">
            <button id="prev-model" class="p-2 text-slate-400 hover:text-emerald-400 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>
            <div class="text-center w-40">
                <p id="model-name" class="text-sm font-extrabold text-white uppercase tracking-widest">Heavy Box Truck</p>
                <p id="model-class" class="text-[10px] text-emerald-400 font-bold mt-0.5">Class 8 Commercial</p>
            </div>
            <button id="next-model" class="p-2 text-slate-400 hover:text-emerald-400 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>
        </div>

        <div class="absolute right-0 top-0 bottom-0 w-96 bg-slate-900/95 backdrop-blur-xl border-l border-slate-800 shadow-2xl z-20 flex flex-col">
            <div class="p-8 border-b border-slate-800/50">
                <h2 class="text-lg font-bold text-white mb-1">Vehicle Specifications</h2>
                <p class="text-xs text-slate-500">Configure deployment parameters</p>
            </div>
            
            <form id="fleetAddForm" class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
                
                <input type="hidden" id="vehicle-type-input" name="vehicleType" value="box-truck">

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Plate Number</label>
                    <input type="text" name="plateNumber" placeholder="e.g. ABC-1234" required
                        class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition placeholder-slate-600 font-mono uppercase">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex justify-between">
                        Max Capacity 
                        <span id="capacity-display" class="text-emerald-400">12,000 kg</span>
                    </label>
                    <input type="range" name="maxCapacity" min="1000" max="30000" step="500" value="12000" id="capacity-slider"
                        class="w-full accent-emerald-500 bg-slate-800 h-2 rounded-lg appearance-none cursor-pointer">
                    <div class="flex justify-between text-[10px] text-slate-500 font-medium mt-2">
                        <span>Light (1t)</span>
                        <span>Heavy (30t)</span>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 flex justify-between">
                        Assigned Driver 
                        <span class="text-slate-600 text-[10px]">(Optional)</span>
                    </label>
                    <div class="relative">
                        <select name="driverId" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-slate-300 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition appearance-none cursor-pointer">
                            <option value="">-- Leave Unassigned --</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>

            </form>

            <div class="p-8 border-t border-slate-800 bg-slate-900/50 shrink-0">
                <button type="submit" form="fleetAddForm" class="w-full py-3.5 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-extrabold rounded-xl shadow-[0_0_15px_rgba(52,211,153,0.4)] transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Register Vehicle
                </button>
            </div>
        </div>
    </main>

    <script src="/js/admin/adminAddFleet.js"></script>
</body>
</html>