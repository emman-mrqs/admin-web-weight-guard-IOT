<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Admin Settings</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/admin/adminSettings.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300 antialiased selection:bg-emerald-500/30 selection:text-emerald-200">

    <%- include('../partials/adminHeaderSidebar', { currentPage: 'settings' }) %>

    <main class="flex-1 flex flex-col overflow-hidden relative bg-slate-950">
        
        <header class="h-20 bg-slate-950/80 backdrop-blur-xl border-b border-white/[0.05] flex items-center justify-between px-8 shrink-0 z-10 sticky top-0 shadow-sm">
            <div>
                <h1 class="text-2xl font-bold text-white tracking-tight">Account Settings</h1>
                <p class="text-sm text-slate-400 font-medium mt-0.5">Manage your profile and security preferences.</p>
            </div>
            
            <div id="notification-area" class="hidden transition-all duration-500 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 shadow-[0_0_15px_rgba(16,185,129,0.1)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span id="notification-text">Action Successful</span>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
            <div class="max-w-6xl mx-auto w-full flex flex-col lg:flex-row gap-8 items-start">
                
                <div class="w-full lg:w-1/3 bg-slate-900/50 backdrop-blur-sm rounded-2xl border border-white/[0.05] overflow-hidden shrink-0 shadow-xl shadow-black/20 relative">
                    <div class="h-32 bg-gradient-to-br from-emerald-900/40 via-slate-800 to-blue-900/20 border-b border-white/[0.05]"></div>
                    
                    <div class="px-6 pb-6 relative">
                        <div class="flex justify-center -mt-16 mb-5">
                            <div class="relative rounded-full bg-slate-900 p-1.5 ring-1 ring-white/[0.05] shadow-lg">
                                <div class="w-24 h-24 rounded-full bg-gradient-to-b from-emerald-500/20 to-emerald-600/5 border border-emerald-500/30 flex items-center justify-center text-3xl font-bold text-emerald-400">
                                    AU
                                </div>
                                <div class="absolute bottom-2 right-2 w-4 h-4 bg-emerald-500 border-2 border-slate-900 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.6)]"></div>
                            </div>
                        </div>
                        
                        <div class="text-center mb-6">
                            <h2 class="text-xl font-bold text-white mb-2 tracking-tight">Super Administrator</h2>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-xs font-semibold border border-blue-500/20 shadow-sm">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                                Full Access
                            </span>
                        </div>
                        
                        <div class="space-y-3 pt-5 border-t border-white/[0.05] text-sm">
                            <div class="flex justify-between items-center group">
                                <span class="text-slate-400 group-hover:text-slate-300 transition-colors">Member since</span>
                                <span class="text-slate-200 font-medium">Oct 12, 2023</span>
                            </div>
                            <div class="flex justify-between items-center group">
                                <span class="text-slate-400 group-hover:text-slate-300 transition-colors">Status</span>
                                <span class="text-emerald-400 font-medium flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Active
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full lg:w-2/3 space-y-6">

                    <div class="bg-slate-900/50 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-white/[0.05] shadow-xl shadow-black/10">
                        <div class="mb-6">
                            <h3 class="text-lg font-semibold text-white tracking-tight">Personal Information</h3>
                            <p class="text-sm text-slate-400 mt-1">Identity details are managed by the Super Admin.</p>
                        </div>
                        
                        <div class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-medium text-slate-400 mb-2">First Name</label>
                                    <div class="relative">
                                        <svg class="w-4 h-4 text-slate-500 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        <input type="text" value="Super" disabled class="w-full bg-slate-950/50 border border-slate-800 text-slate-500 text-sm rounded-xl pl-10 pr-4 py-3 cursor-not-allowed opacity-80">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-slate-400 mb-2">Last Name</label>
                                    <div class="relative">
                                        <svg class="w-4 h-4 text-slate-500 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        <input type="text" value="Administrator" disabled class="w-full bg-slate-950/50 border border-slate-800 text-slate-500 text-sm rounded-xl pl-10 pr-4 py-3 cursor-not-allowed opacity-80">
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-medium text-slate-400 mb-2">Email Address</label>
                                <div class="relative flex items-center">
                                    <svg class="w-4 h-4 text-slate-500 absolute left-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path></svg>
                                    <input type="email" value="admin@weighguard.io" disabled class="w-full bg-slate-950/50 border border-slate-800 text-slate-500 text-sm rounded-xl pl-10 pr-24 py-3 cursor-not-allowed opacity-80">
                                    <div class="absolute right-3 flex items-center gap-1.5 bg-emerald-500/10 px-2 py-1 rounded-md text-emerald-400 text-xs font-semibold border border-emerald-500/20">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                        Verified
                                    </div>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-2">
                                <div class="bg-slate-950/50 border border-white/[0.03] p-4 rounded-xl hover:bg-slate-800/50 transition-colors duration-300">
                                    <p class="text-xs font-medium text-slate-500 mb-1.5">Role</p>
                                    <p class="text-sm text-slate-200 font-semibold">Staff</p>
                                </div>
                                <div class="bg-slate-950/50 border border-white/[0.03] p-4 rounded-xl hover:bg-slate-800/50 transition-colors duration-300">
                                    <p class="text-xs font-medium text-slate-500 mb-1.5">Member Since</p>
                                    <p class="text-sm text-slate-200 font-semibold">Oct 12, 2023</p>
                                </div>
                                <div class="bg-slate-950/50 border border-white/[0.03] p-4 rounded-xl hover:bg-slate-800/50 transition-colors duration-300">
                                    <p class="text-xs font-medium text-slate-500 mb-1.5">Status</p>
                                    <p class="text-sm text-emerald-400 font-semibold">Active</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-900/50 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-white/[0.05] shadow-xl shadow-black/10">
                        <div class="mb-6">
                            <h3 class="text-lg font-semibold text-white tracking-tight">Security</h3>
                            <p class="text-sm text-slate-400 mt-1">Manage your password securely.</p>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <label class="block text-xs font-medium text-slate-400 mb-2">Current Password</label>
                                <div class="relative group">
                                    <svg class="w-4 h-4 text-slate-500 absolute left-3.5 top-1/2 -translate-y-1/2 group-focus-within:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                                    <input type="password" placeholder="••••••••" class="w-full bg-slate-950 border border-slate-700/60 text-white text-sm rounded-xl pl-10 pr-10 py-3 focus:outline-none focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all shadow-inner">
                                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </button>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-medium text-slate-400 mb-2">New Password</label>
                                    <div class="relative group">
                                        <svg class="w-4 h-4 text-slate-500 absolute left-3.5 top-1/2 -translate-y-1/2 group-focus-within:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        <input type="password" placeholder="••••••••" class="w-full bg-slate-950 border border-slate-700/60 text-white text-sm rounded-xl pl-10 pr-10 py-3 focus:outline-none focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all shadow-inner">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-slate-400 mb-2">Confirm Password</label>
                                    <div class="relative group">
                                        <svg class="w-4 h-4 text-slate-500 absolute left-3.5 top-1/2 -translate-y-1/2 group-focus-within:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        <input type="password" placeholder="••••••••" class="w-full bg-slate-950 border border-slate-700/60 text-white text-sm rounded-xl pl-10 pr-10 py-3 focus:outline-none focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all shadow-inner">
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-end pt-4">
                                <button type="button" onclick="document.getElementById('security-modal').classList.remove('hidden', 'opacity-0', 'pointer-events-none')" class="bg-slate-800 hover:bg-slate-700 text-white border border-slate-600/50 hover:border-slate-500 text-sm font-semibold py-2.5 px-6 rounded-xl transition-all duration-300 shadow-sm hover:shadow-md">
                                    Change Password
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <div id="security-modal" class="fixed inset-0 z-50 hidden opacity-0 pointer-events-none transition-all duration-300">
        <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" onclick="this.parentElement.classList.add('hidden', 'opacity-0', 'pointer-events-none')"></div>
        
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-slate-900 border border-white/[0.1] w-full max-w-md rounded-2xl p-8 shadow-2xl shadow-black/50">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-5 border border-emerald-500/20 shadow-[0_0_15px_rgba(16,185,129,0.15)]">
                    <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-white tracking-tight">Change Password?</h3>
                <p class="text-slate-400 text-sm mt-2.5 leading-relaxed px-4">
                    Are you sure you want to change your password? You will need to use this new password the next time you log in.
                </p>
            </div>

            <div class="flex gap-4">
                <button onclick="document.getElementById('security-modal').classList.add('hidden', 'opacity-0', 'pointer-events-none')" class="flex-1 py-3 bg-slate-800/50 border border-white/[0.05] text-slate-300 text-sm font-semibold rounded-xl hover:bg-slate-800 hover:text-white transition-all duration-300">
                    Cancel
                </button>
                <button class="flex-1 py-3 bg-emerald-500 text-slate-950 text-sm font-bold rounded-xl hover:bg-emerald-400 hover:shadow-[0_0_20px_rgba(52,211,153,0.3)] transition-all duration-300">
                    Confirm Change
                </button>
            </div>
        </div>
    </div>

</body>
</html>