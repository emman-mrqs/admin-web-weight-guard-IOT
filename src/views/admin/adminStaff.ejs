                <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 109-9"></path><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v6h6"></path></svg>
                </div>
                <h2 class="text-lg font-extrabold text-white tracking-tight">Restore Deleted Staff?</h2>
            </div>
            <button onclick="closeModal('restoreDeletedStaffModal')" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
        <div class="p-8 space-y-6">
            <input type="hidden" id="restoreDeletedStaffId">
            <div class="bg-emerald-950/20 border border-emerald-500/20 rounded-xl p-4 text-left">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Target Staff Member</p>
                <p class="text-white font-bold mb-2" id="restoreDeletedStaffName">Staff Name Here</p>
                <p class="text-xs text-slate-400 leading-relaxed">This will restore account access and clear the deleted timestamp.</p>
            </div>
            <p id="restoreDeletedFormError" class="text-rose-500 text-xs hidden text-center"></p>
            <p id="restoreDeletedFormSuccess" class="text-emerald-500 text-xs hidden text-center"></p>
            <div class="flex gap-3 pt-4 border-t border-slate-800">
                <button type="button" onclick="closeModal('restoreDeletedStaffModal')" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="confirmRestoreDeletedStaff()" class="flex-1 px-4 py-3 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-bold transition shadow-[0_0_15px_rgba(16,185,129,0.4)] flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 109-9"></path><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v6h6"></path></svg>
                    Restore Staff
                </button>
            </div>
        </div>
    </div>

    <div id="verificationModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-md bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h2 class="text-lg font-extrabold text-white tracking-tight">Verify Account</h2>
        </div>
        
        <div class="p-8 space-y-6">
            <div class="text-center space-y-2 mb-6">
                <p class="text-slate-300 text-sm font-medium">A 6-digit verification code has been sent to</p>
                <p id="verificationEmail" class="text-emerald-400 font-bold text-sm font-mono break-all">email@example.com</p>
                <div class="mt-3">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Code Expires In</p>
                    <p id="verificationTimer" class="mt-1 text-lg font-extrabold text-emerald-300">05:00</p>
                    <div class="mt-2 h-1.5 w-full rounded-full bg-slate-800 overflow-hidden">
                        <div id="verificationTimerBar" class="h-full w-full rounded-full bg-emerald-400 transition-all duration-1000"></div>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Verification Code</label>
                <div class="flex gap-2 justify-center">
                    <input type="text" id="verifyDigit1" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit2" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit3" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit4" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit5" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                    <input type="text" id="verifyDigit6" maxlength="1" class="w-12 h-14 bg-slate-950 border border-slate-700 text-white text-center text-xl font-bold rounded-lg focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition shadow-inner" placeholder="0">
                </div>
            </div>

            <p id="verificationError" class="text-rose-500 text-xs hidden text-center"></p>
            <p id="verificationSuccess" class="text-emerald-500 text-xs hidden text-center"></p>

            <div class="text-center text-xs text-slate-500">
                <p>Didn't receive code? <button type="button" onclick="resendVerificationCode()" class="text-emerald-400 font-bold cursor-pointer hover:text-emerald-300">Resend</button></p>
            </div>

            <div class="flex gap-3">
                <button type="button" onclick="closeModal('verificationModal'); resetVerificationCode()" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button type="button" onclick="submitVerificationCode()" class="flex-1 px-4 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-extrabold transition shadow-[0_0_15px_rgba(52,211,153,0.4)]">Verify</button>
            </div>
        </div>
    </div>
    <script src="/js/admin/adminStaff.js"></script>
</body>
</html>