<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Fleet Directory</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/admin/adminFleet.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden bg-slate-950 relative">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 shrink-0 z-10 sticky top-0">
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">Fleet Directory</h1>
                <p class="text-xs text-slate-400 font-medium mt-0.5">Manage and analyze your entire vehicle roster</p>
            </div>

        </header>

        <div class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
            <!-- Fleet Stats -->
            <div class="grid grid-cols-4 gap-6">
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex items-center gap-4">
                    <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Total Fleet</p>
                        <p id="fleetStatTotal" class="text-2xl font-extrabold text-white leading-none">0</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
                    <div class="p-3 bg-slate-800/50 rounded-xl text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Active</p>
                        <p id="fleetStatActive" class="text-2xl font-extrabold text-white leading-none">0</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.5)]"></div>
                    <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-amber-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Avg Load</p>
                        <p id="fleetStatAvgCapacity" class="text-2xl font-extrabold text-white leading-none">0 <span class="text-sm font-semibold text-slate-500">kg</span></p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]"></div>
                    <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl text-rose-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Loss Events</p>
                        <p id="fleetStatAlerts" class="text-2xl font-extrabold text-rose-400 leading-none">0</p>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex flex-col overflow-hidden">
                <!-- Fleet Controls Filter -->
                <div class="p-5 px-6 flex justify-between items-center border-b border-slate-800 bg-slate-900/50">
                    <div class="flex gap-2" id="filter-buttons">
                        <button onclick="filterFleet('all', this)" class="filter-btn px-4 py-2 bg-slate-800 text-white text-xs font-bold rounded-lg border border-slate-700 hover:bg-slate-700 transition shadow-md">
                            All Vehicles
                        </button>
                        <button onclick="filterFleet('active', this)" class="filter-btn px-4 py-2 bg-transparent text-slate-400 text-xs font-bold rounded-lg border border-transparent hover:text-slate-200 transition">
                            Active (<span id="fleetActiveCount">0</span>)
                        </button>
                        <button onclick="filterFleet('maintenance', this)" class="filter-btn px-4 py-2 bg-transparent text-amber-400 text-xs font-bold rounded-lg border border-transparent hover:bg-amber-500/10 transition flex items-center gap-2">
                            Maintenance (<span id="fleetMaintenanceCount">0</span>)
                        </button>
                        <button onclick="filterFleet('alert', this)" class="filter-btn px-4 py-2 bg-transparent text-rose-400 text-xs font-bold rounded-lg border border-transparent hover:bg-rose-500/10 transition flex items-center gap-2">
                            Alerts (<span id="fleetAlertCount">0</span>)
                            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span></span>
                        </button>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <input id="fleetSearchInput" type="text" placeholder="Search plate, type, driver..." class="w-64 bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-xs text-slate-200 placeholder-slate-500 focus:outline-none focus:border-emerald-500">
                        </div>
                        <a href="/admin/fleet/add" class="flex items-center gap-2 px-4 py-2 bg-emerald-500/10 text-emerald-400 text-xs font-bold rounded-lg border border-emerald-500/30 hover:bg-emerald-500/20 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                            Add Vehicle
                        </a>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="text-slate-500 text-[10px] uppercase tracking-widest font-bold bg-slate-900/80 border-b border-slate-800">
                                <th class="px-6 py-4">Vehicle Details</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Route / Location</th>
                                <th class="px-6 py-4">Current Load</th>
                                <th class="px-6 py-4">Weight Trend (1h)</th>
                                <th class="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/50" id="fleet-table-body">
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-slate-500 text-sm">
                                    Loading fleet data...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="p-4 px-6 border-t border-slate-800 bg-slate-900/50 flex items-center justify-between">
                    <p class="text-xs text-slate-500 font-medium" id="pagination-info">
                        Loading entries...
                    </p>
                    <div class="flex items-center gap-1.5" id="pagination-controls">
                        <button class="p-2 rounded-lg border border-slate-700 text-slate-400 opacity-50 cursor-not-allowed bg-slate-800/50" disabled><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg></button>
                        <button class="w-8 h-8 flex items-center justify-center rounded-lg border bg-emerald-500/10 border-emerald-500/30 text-emerald-400 text-xs font-bold" disabled>1</button>
                        <button class="p-2 rounded-lg border border-slate-700 text-slate-400 opacity-50 cursor-not-allowed bg-slate-800/50" disabled><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <div id="modalOverlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300" onclick="closeAllModals()"></div>

    <div id="viewModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-2xl bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-start">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <h2 id="viewVehicleType" class="text-2xl font-extrabold text-white tracking-tight">Trailer Truck</h2>
                    <span id="viewStatusBadge" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold tracking-wide">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                        IN TRANSIT
                    </span>
                </div>
                <p id="viewPlateNumber" class="text-sm text-slate-400 font-mono tracking-wide">RC-8802</p>
            </div>
            <button onclick="closeAllModals()" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>

        <div class="p-8 space-y-6">
            <div class="grid grid-cols-2 gap-6">
                <div class="flex items-center gap-4 p-4 rounded-xl border border-slate-800 bg-slate-950/50">
                    <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-emerald-500 to-teal-500 flex items-center justify-center text-white font-bold text-lg shadow-lg">ML</div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Assigned Driver</p>
                        <p id="viewDriverName" class="text-sm font-bold text-white">Marcus Lee</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl border border-slate-800 bg-slate-950/50">
                    <div class="w-12 h-12 rounded-xl bg-slate-800 text-emerald-400 flex items-center justify-center border border-slate-700">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-0.5">Current Location</p>
                        <p id="viewCurrentState" class="text-sm font-bold text-white">Route A-12 <span class="text-xs font-mono text-slate-500 ml-1">(34.06, -118.34)</span></p>
                    </div>
                </div>
            </div>

            <div class="p-5 rounded-xl border border-slate-800 bg-slate-950/50">
                <div class="flex justify-between items-end mb-3">
                    <div>
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Current Cargo Load</p>
                        <p id="viewCurrentLoad" class="text-2xl font-extrabold text-white leading-none">920 <span class="text-sm font-medium text-slate-500">kg</span></p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Max Capacity</p>
                        <p id="viewMaxCapacity" class="text-sm font-bold text-emerald-400">1,200 kg</p>
                    </div>
                </div>
                <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                    <div id="viewLoadProgressBar" class="bg-gradient-to-r from-emerald-500 to-teal-400 h-full rounded-full shadow-[0_0_10px_rgba(52,211,153,0.5)]" style="width: 0%"></div>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4 border-t border-slate-800 pt-6">
                <div>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Class</p>
                    <p id="viewVehicleClass" class="text-sm font-bold text-slate-300">Class 8 Heavy Duty</p>
                </div>
                <div>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Deploy Date</p>
                    <p id="viewCreatedAt" class="text-sm font-bold text-slate-300">Oct 12, 2025</p>
                </div>
                <div>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Last Maintenance</p>
                    <p id="viewLastMaintenance" class="text-sm font-bold text-slate-300">Jan 04, 2026</p>
                </div>
            </div>
        </div>
    </div>

    <div id="editModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-2xl bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-start">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-8 h-8 rounded-lg bg-blue-500/10 text-blue-400 flex items-center justify-center border border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.2)]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    </div>
                    <h2 class="text-xl font-extrabold text-white tracking-tight">Edit Vehicle Config</h2>
                </div>
                <p class="text-xs text-slate-400 font-medium mt-1">Update parameters for <span class="font-mono text-slate-300 font-bold">RC-8802</span></p>
            </div>
            <button onclick="closeAllModals()" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>

        <form id="editFleetForm" class="p-8 space-y-6">
            <input type="hidden" id="editVehicleId" name="vehicleId">
            <div id="editFleetFormFeedback" class="hidden rounded-xl border px-4 py-3 text-sm font-medium"></div>
            
            <div class="grid grid-cols-2 gap-6">
                <div class="col-span-2 sm:col-span-1">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Plate Number / ID</label>
                    <input id="editPlateNumber" name="plateNumber" type="text" value="RC-8802" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3.5 text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition uppercase font-mono shadow-inner">
                </div>
                
                <div class="col-span-2 sm:col-span-1">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Vehicle Type</label>
                    <div class="relative">
                        <select id="editVehicleType" name="vehicleType" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3.5 text-slate-300 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition appearance-none cursor-pointer shadow-inner">
                            <option value="Trailer Truck">Trailer Truck</option>
                            <option value="Flatbed Truck">Flatbed Truck</option>
                            <option value="Reefer Box Truck">Reefer Box Truck</option>
                            <option value="Small Truck">Small Truck</option>
                            <option value="Box Truck">Box Truck</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-6">
                <div class="col-span-2">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 flex justify-between">
                        Max Capacity
                        <span id="editCapacityDisplay" class="text-blue-400">12,000 kg</span>
                    </label>
                    <input id="editMaxCapacity" name="maxCapacity" type="range" min="1000" max="30000" step="500" value="12000" class="w-full accent-blue-500 bg-slate-800 h-2 rounded-lg appearance-none cursor-pointer">
                    <div class="flex justify-between text-[10px] text-slate-500 font-medium mt-2">
                        <span>Light (1t)</span>
                        <span>Heavy (30t)</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-6">
                <div class="col-span-2 sm:col-span-1">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Assigned Driver</label>
                    <div class="relative">
                        <select id="editDriverId" name="driverId" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3.5 text-slate-300 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition appearance-none cursor-pointer shadow-inner">
                            <option value="">-- Unassigned --</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
                
                <div class="col-span-2 sm:col-span-1">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Operational Status</label>
                    <div class="relative">
                        <select id="editCurrentState" name="currentState" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3.5 text-emerald-400 font-bold focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition appearance-none cursor-pointer shadow-inner">
                            <option value="available" selected>Available</option>
                            <option value="in_transit" class="text-slate-400 font-medium">In Transit</option>
                            <option value="idle" class="text-slate-400 font-medium">Idle / Docked</option>
                            <option value="maintenance" class="text-amber-400 font-medium">In Maintenance</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-800 flex gap-4 mt-2">
                <button type="button" onclick="closeAllModals()" class="w-1/3 py-3.5 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 hover:text-white transition">Cancel</button>
                <button type="submit" class="w-2/3 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-extrabold transition shadow-[0_0_15px_rgba(37,99,235,0.4)] flex items-center justify-center gap-2 tracking-wide uppercase text-xs">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Save Configuration
                </button>
            </div>
        </form>
    </div>

    <div id="deleteModal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-full max-w-md bg-slate-900 border border-slate-700/50 rounded-2xl shadow-2xl hidden opacity-0 scale-95 transition-all duration-300 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-rose-500/10 text-rose-400 flex items-center justify-center border border-rose-500/20 shadow-[0_0_10px_rgba(244,63,94,0.2)]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </div>
                <h2 class="text-lg font-extrabold text-white tracking-tight">Delete Vehicle Permanently?</h2>
            </div>
            <button onclick="closeAllModals()" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>

        <div class="p-8 space-y-6">
            <div class="bg-rose-950/20 border border-rose-500/20 rounded-xl p-4 text-left">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Target Vehicle</p>
                <p class="text-white font-bold mb-2 font-mono" id="deletePlateNumber">RC-8802</p>
                <p class="text-xs text-slate-400 leading-relaxed">This action permanently deletes the vehicle record and cannot be undone.</p>
            </div>

            <p id="deleteFleetFormError" class="text-rose-500 text-xs hidden text-center"></p>

            <div class="flex gap-3 pt-4 border-t border-slate-800">
                <button type="button" onclick="closeAllModals()" class="flex-1 px-4 py-3 rounded-xl border border-slate-700 text-slate-300 font-bold hover:bg-slate-800 transition">Cancel</button>
                <button id="confirmDeleteVehicleBtn" type="button" class="flex-1 px-4 py-3 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-bold transition shadow-[0_0_15px_rgba(225,29,72,0.4)] flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete Vehicle
                </button>
            </div>
        </div>
    </div>

    <script src="/js/admin/adminFleet.js"></script>
