<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Fleet Management Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/admin/adminDashboard.css">
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden bg-slate-950">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 z-10 sticky top-0">
            <h1 class="text-2xl font-extrabold text-white tracking-tight">Dashboard Overview</h1>
            
            <div class="flex items-center gap-6">
                <div class="relative group">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none">
                        <svg class="w-4 h-4 text-slate-500 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </span>
                    <input type="text" placeholder="Search vehicle ID, status..." class="bg-slate-900 border border-slate-700 text-sm rounded-xl pl-10 pr-4 py-2.5 w-72 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 text-slate-200 transition-all placeholder-slate-500 shadow-inner">
                </div>
                
                <button class="relative p-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-xl transition-all duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    <span class="absolute top-2 right-2.5 w-2 h-2 bg-rose-500 rounded-full border-2 border-slate-900 shadow-[0_0_8px_rgba(244,63,94,0.6)]"></span>
                </button>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 space-y-8 custom-scrollbar">
            
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
                
                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 hover:border-slate-700 transition-colors">
                    <div class="flex justify-between items-start mb-4">
                        <p class="text-slate-400 text-sm font-semibold tracking-wide">Active Fleet</p>
                        <div class="p-2 bg-emerald-500/10 rounded-lg text-emerald-400 border border-emerald-500/20">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path></svg>
                        </div>
                    </div>
                    <div class="flex items-end gap-3 mb-4">
                        <h2 class="text-4xl font-extrabold text-white leading-none">120</h2>
                        <span class="text-emerald-400 text-xs font-bold px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded-md mb-1 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                            100%
                        </span>
                    </div>
                    <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                        <div class="bg-gradient-to-r from-emerald-500 to-teal-400 h-full rounded-full w-full shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
                    </div>
                </div>

                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 hover:border-slate-700 transition-colors">
                    <p class="text-slate-400 text-sm font-semibold tracking-wide mb-5">Cargo Status</p>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between text-sm">
                            <div class="flex items-center gap-2.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)]"></span>
                                <span class="text-slate-300 font-medium">Normal Capacity</span>
                            </div>
                            <span class="font-bold text-white">84</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <div class="flex items-center gap-2.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.6)]"></span>
                                <span class="text-slate-300 font-medium">Overloaded Warning</span>
                            </div>
                            <span class="font-bold text-white">26</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <div class="flex items-center gap-2.5">
                                <span class="w-2.5 h-2.5 rounded-full bg-rose-400 shadow-[0_0_8px_rgba(251,113,133,0.6)]"></span>
                                <span class="text-slate-300 font-medium">Potential Loss</span>
                            </div>
                            <span class="font-bold text-white">10</span>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 hover:border-slate-700 transition-colors">
                    <p class="text-slate-400 text-sm font-semibold tracking-wide mb-4">Today's Active Alerts</p>
                    <div class="flex gap-4 h-[72px]">
                        <div class="flex-1 bg-rose-500/10 border border-rose-500/20 rounded-xl flex flex-col items-center justify-center">
                            <p class="text-rose-400 text-2xl font-extrabold leading-none">3</p>
                            <p class="text-rose-500/80 text-[10px] uppercase font-bold tracking-widest mt-1">Critical</p>
                        </div>
                        <div class="flex-1 bg-amber-500/10 border border-amber-500/20 rounded-xl flex flex-col items-center justify-center">
                            <p class="text-amber-400 text-2xl font-extrabold leading-none">4</p>
                            <p class="text-amber-500/80 text-[10px] uppercase font-bold tracking-widest mt-1">Warning</p>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 hover:border-slate-700 transition-colors relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-rose-500 shadow-[0_0_15px_rgba(244,63,94,0.6)]"></div>
                    
                    <p class="text-slate-400 text-sm font-semibold tracking-wide mb-2 pl-2">Total Loss Events</p>
                    <div class="pl-2">
                        <h2 class="text-5xl font-extrabold text-white">32</h2>
                        <div class="flex items-center gap-2 mt-3 text-slate-400 text-xs font-medium bg-slate-800/50 py-1.5 px-2 rounded border border-slate-700/50 inline-flex">
                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            Recorded in last 30 days
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                <div class="xl:col-span-2 bg-slate-900 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex flex-col overflow-hidden">
                    <div class="p-5 px-6 flex justify-between items-center border-b border-slate-800 bg-slate-900/50">
                        <h3 class="text-lg font-bold text-white">Live Vehicle Status</h3>
                        <button class="text-sm text-emerald-400 font-semibold hover:text-emerald-300 transition-colors">View All Vehicles &rarr;</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-slate-500 text-[11px] uppercase tracking-wider font-bold bg-slate-900/80 border-b border-slate-800">
                                    <th class="px-6 py-4 font-semibold">Vehicle ID</th>
                                    <th class="px-6 py-4 font-semibold">Load Status</th>
                                    <th class="px-6 py-4 font-semibold">GPS Location</th>
                                    <th class="px-6 py-4 font-semibold text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/50">
                                <tr class="hover:bg-slate-800/40 transition-colors group">
                                    <td class="px-6 py-4">
                                        <div class="font-bold text-white">#001</div>
                                        <div class="text-xs text-slate-500 mt-0.5 font-medium">RC Pickup</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[11px] font-bold tracking-wide">NORMAL</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                            <span class="font-mono text-sm text-slate-400 font-medium">34.0653, -118.349</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-500 hover:text-emerald-400 transition p-2 rounded-lg hover:bg-slate-800"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg></button>
                                    </td>
                                </tr>
                                <tr class="hover:bg-slate-800/40 transition-colors group">
                                    <td class="px-6 py-4">
                                        <div class="font-bold text-white">#002</div>
                                        <div class="text-xs text-slate-500 mt-0.5 font-medium">RC Pickup</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded-full bg-amber-500/10 text-amber-400 border border-amber-500/20 text-[11px] font-bold tracking-wide">OVERLOADED</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                            <span class="font-mono text-sm text-slate-400 font-medium">34.0063, -118.349</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-500 hover:text-emerald-400 transition p-2 rounded-lg hover:bg-slate-800"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 relative overflow-hidden h-[350px] xl:h-auto group">
                    <div class="absolute inset-0 bg-slate-950" id="map-container">
                        <div class="w-full h-full opacity-60 bg-[url('https://api.mapbox.com/styles/v1/mapbox/dark-v10/static/-118.349,34.0653,10/400x400?access_token=none')] bg-cover mix-blend-screen transition-opacity group-hover:opacity-80"></div>
                    </div>
                    
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-[85%]">
                        <div class="bg-slate-900/95 backdrop-blur-md border border-rose-500/50 p-4 rounded-xl shadow-[0_8px_30px_rgba(0,0,0,0.5)] flex items-center gap-4">
                            <div class="relative flex h-4 w-4 shrink-0">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-4 w-4 bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.8)]"></span>
                            </div>
                            <div>
                                <p class="text-[10px] font-extrabold text-rose-400 uppercase tracking-wider mb-0.5">Alert: Cargo Loss</p>
                                <p class="text-sm font-bold text-white">Vehicle: RC Pickup #003</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-6">
                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20">
                    <div class="flex justify-between items-center mb-6">
                        <div>
                            <h3 class="text-lg font-bold text-white">Weight Fluctuation History</h3>
                            <p class="text-xs text-slate-500 mt-1 font-medium">Tracking fleet average over 24 hours</p>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 rounded-lg border border-emerald-500/20 text-emerald-400">
                            <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_5px_rgba(52,211,153,0.8)]"></div>
                            <span class="text-[10px] uppercase font-bold tracking-wide">Live Updates</span>
                        </div>
                    </div>
                    <div class="h-[250px] w-full">
                        <canvas id="cargoWeightChart"></canvas>
                    </div>
                </div>

                <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-lg shadow-black/20 flex flex-col">
                    <div class="mb-2">
                        <h3 class="text-lg font-bold text-white">Fleet Composition</h3>
                        <p class="text-xs text-slate-500 mt-1 font-medium">Current distribution of vehicle statuses</p>
                    </div>
                    <div class="flex-1 flex items-center justify-center relative min-h-[250px]">
                        <div class="h-[220px] w-full">
                            <canvas id="fleetStatusChart"></canvas>
                        </div>
                        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-2">
                            <p class="text-4xl font-extrabold text-white">120</p>
                            <p class="text-[11px] text-slate-500 uppercase font-bold tracking-widest mt-1">Total Fleet</p>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </main>

    <script src="/js/admin/adminDashboard.js"></script>
</body>
</html>