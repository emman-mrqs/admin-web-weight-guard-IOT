<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeighGuard - Incident & Alert Logs</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/admin/adminIncidents.css">
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    </style>
</head>
<body class="flex h-screen overflow-hidden bg-slate-950 font-sans text-slate-300">

    <%- include('../partials/adminHeaderSidebar',  { currentPage: currentPage }) %>

    <main class="flex-1 flex flex-col overflow-hidden relative bg-slate-950">
        
        <header class="h-20 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex items-center justify-between px-8 shrink-0 z-10 sticky top-0">
            <div>
                <h1 class="text-2xl font-extrabold text-white tracking-tight">Incident & Alert Logs</h1>
                <p class="text-xs text-slate-400 font-medium mt-0.5">Monitoring cargo weight and detecting theft/loss in real-time</p>
            </div>
            <div class="flex items-center gap-6">
                <div class="flex bg-slate-950 rounded-xl p-1.5 border border-slate-800 shadow-inner">
                    <button id="btnActiveView" class="px-5 py-2 text-xs font-bold uppercase tracking-widest bg-slate-800 text-white rounded-lg shadow-sm transition">ACTIVE</button>
                    <button id="btnHistoryView" class="px-5 py-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-slate-300 rounded-lg transition">HISTORY</button>
                </div>
                <button id="btnRefresh" class="bg-slate-800 border border-slate-700 text-slate-300 p-2.5 rounded-xl hover:bg-slate-700 hover:text-white transition shadow-sm" title="Refresh Data">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                </button>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 shrink-0">
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]"></div>
                    <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl text-rose-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-0.5">High</p>
                        <p id="statCritical" class="text-2xl font-extrabold text-rose-400 leading-none">0</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.5)]"></div>
                    <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-amber-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-0.5">Medium</p>
                        <p id="statWarning" class="text-2xl font-extrabold text-amber-400 leading-none">0</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
                    <div class="p-3 bg-blue-500/10 border border-blue-500/20 rounded-xl text-blue-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-0.5">Open Incidents</p>
                        <p id="statOpen" class="text-2xl font-extrabold text-blue-400 leading-none">0</p>
                    </div>
                </div>
                <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 shadow-lg flex items-center gap-4">
                    <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-0.5">Last 24h</p>
                        <p id="statRecent" class="text-2xl font-extrabold text-white leading-none">0</p>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg overflow-hidden p-1.5 relative h-[350px] shrink-0">
                <div id="incidentMap" class="w-full h-full rounded-xl z-0"></div>
                
                <div class="absolute top-6 left-6 z-[1000] flex flex-col gap-2">
                    <div class="bg-slate-900/90 backdrop-blur-md border border-slate-700/50 px-4 py-2.5 rounded-xl shadow-xl">
                        <p class="text-[10px] font-bold text-rose-400 uppercase tracking-widest flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse shadow-[0_0_5px_rgba(244,63,94,0.8)]"></span>
                            Live Incident Tracking
                        </p>
                    </div>
                </div>
                
                <div class="absolute bottom-6 left-6 z-[1000] bg-slate-900/90 backdrop-blur-md border border-slate-700/50 px-4 py-3 rounded-xl shadow-xl">
                    <div class="flex items-center gap-4 text-xs font-bold tracking-wide">
                        <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-rose-500 shadow-[0_0_5px_rgba(244,63,94,0.8)]"></span> High</span>
                        <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-amber-500 shadow-[0_0_5px_rgba(251,191,36,0.8)]"></span> Medium</span>
                        <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-[0_0_5px_rgba(59,130,246,0.8)]"></span> Normal</span>
                    </div>
                </div>
            </div>

            <section class="bg-slate-900 rounded-2xl border border-slate-800 shadow-lg overflow-hidden w-full">
                <div class="p-5 px-6 border-b border-slate-800 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 bg-slate-900/50">
                    <h3 class="text-lg font-extrabold text-white tracking-tight">Full Incident Log</h3>
                    <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto">
                        <select id="filterType" class="bg-slate-950 border border-slate-700 text-xs font-bold text-slate-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-emerald-500 appearance-none cursor-pointer shadow-inner flex-1">
                            <option value="">All Types</option>
                            <option value="loss">Cargo Loss</option>
                            <option value="overload">Overload</option>
                            <option value="route_deviation">Route Deviation</option>
                            <option value="unauthorized_stop">Unauthorized Stop</option>
                        </select>
                        <select id="filterStatus" class="bg-slate-950 border border-slate-700 text-xs font-bold text-slate-300 rounded-xl px-4 py-2.5 focus:outline-none focus:border-emerald-500 appearance-none cursor-pointer shadow-inner flex-1">
                            <option value="">All Status</option>
                            <option value="pending">Pending</option>
                            <option value="open">Open</option>
                            <option value="acknowledged">Acknowledged</option>
                            <option value="investigating">Investigating</option>
                            <option value="resolved">Resolved</option>
                            <option value="false_alarm">False Alarm</option>
                        </select>
                        <button id="btnExport" class="bg-slate-800 text-emerald-400 border border-slate-700 px-4 py-2.5 rounded-xl text-xs font-extrabold flex items-center justify-center gap-2 hover:bg-slate-700 transition shadow-sm uppercase tracking-widest shrink-0">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            EXPORT LOG
                        </button>
                    </div>
                </div>
                <div id="incidentTableError" class="hidden px-6 py-3 text-xs font-semibold text-rose-300 bg-rose-500/10 border-b border-rose-500/20"></div>
                <div class="overflow-x-auto custom-scrollbar">
                    <table class="w-full min-w-[1150px] text-left border-collapse">
                        <thead class="bg-slate-900/90 backdrop-blur">
                            <tr class="text-slate-500 text-[10px] uppercase tracking-widest font-bold border-b border-slate-800">
                                <th class="px-6 py-4">Timestamp</th>
                                <th class="px-6 py-4">Incident Type</th>
                                <th class="px-6 py-4">Severity</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Dispatch Task</th>
                                <th class="px-6 py-4">Vehicle / Driver</th>
                                <th class="px-6 py-4">Weight Impact</th>
                                <th class="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="incidentTableBody" class="divide-y divide-slate-800/50">
                            <tr>
                                <td colspan="8" class="px-6 py-8 text-center text-slate-500 text-xs">Loading incidents...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="p-4 px-6 border-t border-slate-800 bg-slate-900/50 flex items-center justify-between">
                    <p class="text-xs text-slate-500 font-medium" id="incidentPaginationInfo">Loading entries...</p>
                    <div class="flex items-center gap-1.5" id="incidentPaginationControls"></div>
                </div>
            </section>
        </div>
    </main>

    <div id="incidentDetailModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[2000] hidden flex items-center justify-center p-4">
        <div class="bg-slate-900 rounded-2xl border border-slate-700/50 w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col shadow-2xl">
            
            <div class="px-8 py-6 border-b border-slate-800 flex justify-between items-center bg-slate-900/50 shrink-0">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-rose-500/10 text-rose-500 flex items-center justify-center border border-rose-500/20 shadow-[0_0_10px_rgba(244,63,94,0.2)]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <div>
                        <h3 id="modalTitle" class="text-xl font-extrabold text-white tracking-tight">Incident Details</h3>
                        <p id="modalSubtitle" class="text-xs text-slate-400 font-mono mt-0.5"></p>
                    </div>
                </div>
                <button id="btnCloseModal" class="text-slate-500 hover:text-white bg-slate-800 hover:bg-slate-700 p-2 rounded-xl transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1.5">Type</p>
                        <p id="modalType" class="text-sm font-bold text-white">-</p>
                    </div>
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1.5">Severity</p>
                        <p id="modalSeverity" class="text-sm font-bold">-</p>
                    </div>
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1.5">Initial Weight</p>
                        <p id="modalInitialWeight" class="text-sm font-bold text-white font-mono">-</p>
                    </div>
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1.5">Weight Lost</p>
                        <p id="modalWeightDiff" class="text-sm font-bold text-rose-500 font-mono">-</p>
                    </div>
                </div>
                
                <div class="bg-slate-950 p-5 rounded-xl border border-slate-800 shadow-inner">
                    <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-2">Description</p>
                    <p id="modalDescription" class="text-sm text-slate-300 leading-relaxed">-</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner flex flex-col">
                        <div class="flex items-center justify-between mb-3">
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Incident Location</p>
                            <button id="btnFocusIncidentMap" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wide rounded-lg border border-sky-500/30 text-sky-300 bg-sky-500/10 hover:bg-sky-500/20 transition">
                                Show On Main Map
                            </button>
                        </div>
                        <div id="modalMap" class="flex-1 min-h-[250px] rounded-lg border border-slate-700/50 z-0"></div>
                    </div>
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 shadow-inner flex flex-col">
                        <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-3">Weight Timeline</p>
                        <div id="weightChartContainer" class="flex-1 min-h-[250px] flex items-center justify-center">
                            <canvas id="weightChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-950 p-5 rounded-xl border border-slate-800 shadow-inner">
                    <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-3">Incident Lifecycle History</p>
                    <div id="modalHistoryContainer" class="space-y-2 text-xs"></div>
                </div>

                <div id="statusUpdateSection" class="bg-slate-950 p-5 rounded-xl border border-slate-800 shadow-inner">
                    <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-3">Update Resolution Status</p>
                    <div id="statusUpdateError" class="hidden mb-3 text-xs text-rose-300 bg-rose-500/10 border border-rose-500/30 rounded-lg px-3 py-2"></div>
                    <div class="flex gap-3 flex-wrap mb-4">
                        <button data-status="acknowledged" class="status-btn px-5 py-2.5 bg-blue-500/10 border border-blue-500/30 text-blue-400 text-xs font-bold rounded-lg hover:bg-blue-500/20 hover:border-blue-500 transition shadow-sm uppercase tracking-wide">Acknowledge</button>
                        <button data-status="investigating" class="status-btn px-5 py-2.5 bg-amber-500/10 border border-amber-500/30 text-amber-400 text-xs font-bold rounded-lg hover:bg-amber-500/20 hover:border-amber-500 transition shadow-sm uppercase tracking-wide">Investigate</button>
                        <button data-status="resolved" class="status-btn px-5 py-2.5 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-bold rounded-lg hover:bg-emerald-500/20 hover:border-emerald-500 transition shadow-sm uppercase tracking-wide">Resolve</button>
                        <button data-status="false_alarm" class="status-btn px-5 py-2.5 bg-slate-800 border border-slate-600 text-slate-300 text-xs font-bold rounded-lg hover:bg-slate-700 transition shadow-sm uppercase tracking-wide">False Alarm</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="statusConfirmModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[2100] hidden flex items-center justify-center p-4">
        <div class="w-full max-w-md rounded-2xl border border-slate-700/50 bg-slate-900 shadow-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-800">
                <h4 class="text-lg font-extrabold text-white tracking-tight">Confirm Status Change</h4>
                <p id="statusConfirmMessage" class="mt-1 text-sm text-slate-300">Are you sure?</p>
            </div>
            <div class="px-6 py-4 flex justify-end gap-3">
                <button id="btnCancelStatusConfirm" class="px-4 py-2 text-xs font-bold uppercase tracking-wide rounded-lg border border-slate-600 text-slate-300 hover:bg-slate-800 transition">Cancel</button>
                <button id="btnConfirmStatusChange" class="px-4 py-2 text-xs font-bold uppercase tracking-wide rounded-lg border border-emerald-500/40 text-emerald-300 bg-emerald-500/10 hover:bg-emerald-500/20 transition">Confirm</button>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/admin/adminIncidents.js"></script>
</body>
</html>