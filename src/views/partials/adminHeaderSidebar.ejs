<script>
    (function () {
        const badge = document.getElementById('incidentSidebarBadge');
        if (!badge) {
            return;
        }

        const applyCount = (value) => {
            const count = Number(value);
            if (!Number.isFinite(count) || count <= 0) {
                badge.textContent = '0';
                badge.classList.add('hidden');
                return;
            }

            badge.textContent = String(count > 99 ? '99+' : count);
            badge.classList.remove('hidden');
        };

        fetch('/api/admin/incidents/count', {
            method: 'GET',
            credentials: 'same-origin'
        })
            .then((response) => {
                if (!response.ok) {
                    throw new Error('Failed to load incident count');
                }
                return response.json();
            })
            .then((payload) => {
                applyCount(payload?.count || 0);
            })
            .catch(() => {
                badge.classList.add('hidden');
            });
    })();

    (function () {
        const modal = document.getElementById('sidebarLogoutModal');
        const dialog = document.getElementById('sidebarLogoutDialog');
        const sessionMenuWrap = document.getElementById('sidebarSessionMenuWrap');
        const menu = document.getElementById('sidebarSessionMenu');
        const menuToggleBtn = document.getElementById('openSidebarSessionMenu');
        const openBtn = document.getElementById('openSidebarLogoutModal');
        const closeBtn = document.getElementById('closeSidebarLogoutModal');
        const cancelBtn = document.getElementById('cancelSidebarLogout');
        const confirmBtn = document.getElementById('confirmSidebarLogout');
        const backdrop = document.getElementById('sidebarLogoutBackdrop');
        const logoutForm = document.getElementById('sidebarLogoutForm');

        if (!modal || !menu || !menuToggleBtn || !openBtn || !confirmBtn || !logoutForm) {
            return;
        }

        const closeMenu = () => {
            menu.classList.add('hidden');
            menuToggleBtn.setAttribute('aria-expanded', 'false');
        };

        const toggleMenu = () => {
            const willOpen = menu.classList.contains('hidden');
            if (willOpen) {
                menu.classList.remove('hidden');
                menuToggleBtn.setAttribute('aria-expanded', 'true');
            } else {
                closeMenu();
            }
        };

        const closeModal = () => {
            if (backdrop) {
                backdrop.classList.remove('opacity-100');
                backdrop.classList.add('opacity-0');
            }

            if (dialog) {
                dialog.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
                dialog.classList.add('opacity-0', 'scale-95', 'translate-y-1');
            }

            setTimeout(() => {
                modal.classList.add('hidden');
                modal.setAttribute('aria-hidden', 'true');
            }, 180);
        };

        const openModal = () => {
            modal.classList.remove('hidden');

            requestAnimationFrame(() => {
                if (backdrop) {
                    backdrop.classList.remove('opacity-0');
                    backdrop.classList.add('opacity-100');
                }

                if (dialog) {
                    dialog.classList.remove('opacity-0', 'scale-95', 'translate-y-1');
                    dialog.classList.add('opacity-100', 'scale-100', 'translate-y-0');
                }
            });

            modal.setAttribute('aria-hidden', 'false');
        };

        menuToggleBtn.addEventListener('click', toggleMenu);
        openBtn.addEventListener('click', () => {
            closeMenu();
            openModal();
        });
        confirmBtn.addEventListener('click', () => logoutForm.submit());

        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
        if (backdrop) backdrop.addEventListener('click', closeModal);

        document.addEventListener('click', (event) => {
            if (!sessionMenuWrap?.contains(event.target)) {
                closeMenu();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !menu.classList.contains('hidden')) {
                closeMenu();
            }

            if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
                closeModal();
            }
        });
    })();
</script>