                <p class="mt-2 text-sm text-slate-300 leading-relaxed">Are you sure you want to end your session?</p>
            </div>

            <div class="px-6 pb-6 flex gap-3">
                <button id="cancelSidebarLogout" type="button" class="flex-1 rounded-xl border border-slate-600/80 px-3 py-2.5 text-xs font-semibold text-slate-200 hover:bg-slate-800/90 transition">Cancel</button>
                <button id="confirmSidebarLogout" type="button" class="flex-1 rounded-xl bg-rose-500 hover:bg-rose-400 px-3 py-2.5 text-xs font-semibold text-white transition shadow-lg shadow-rose-700/30">Sign out</button>
            </div>

            <button id="closeSidebarLogoutModal" type="button" class="absolute top-3 right-3 p-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800/90 transition" aria-label="Close">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
