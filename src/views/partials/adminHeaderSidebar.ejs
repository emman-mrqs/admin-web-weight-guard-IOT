        <div id="sidebarLogoutDialog" class="w-full max-w-[360px] rounded-2xl border border-slate-700/80 bg-gradient-to-b from-slate-900 to-slate-950 shadow-2xl shadow-black/50 overflow-hidden transition-all duration-200 opacity-0 scale-95 translate-y-1">
