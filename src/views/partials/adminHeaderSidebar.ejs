<div id="sidebarLogoutModal" class="fixed inset-0 z-[120] hidden" aria-hidden="true">
    <div id="sidebarLogoutBackdrop" class="absolute inset-0 bg-slate-950/75 backdrop-blur-sm transition-opacity duration-200 opacity-0"></div>
